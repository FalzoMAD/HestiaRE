#!/bin/bash
# info: add rspamd antispam (with Bayes Redis companion)
# options: NONE
#
# example: h-add-sys-rspamd
#
# Installs and wires rspamd as the antispam system: curated local.d set
# (controller and scan worker on group-restricted unix sockets), random
# controller password (overrides the stock "q1"), panel web UI via
# Panel-Caddy (/list/rspamd/, admin-session-gated), exim integration by
# enabling the RSPAMD/SPAM_SCORE macros in the active template. Redis comes
# along as the Bayes backend: unrestricted if selected as a general service
# (DB_REDIS), otherwise as the hard-capped companion — lifecycle contract
# from #299/#121 (h-add/h-delete-sys-redis promote/demote it).
# Also called by the installer (COMPONENT_ADDON_RSPAMD).
# New h-* command — no v-* symlink.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
# live component state
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Checking root permissions
if [ "x$(id -u)" != 'x0' ]; then
	echo "Error: Script can be run executed only by root"
	exit 10
fi

is_system_enabled "$MAIL_SYSTEM" 'MAIL_SYSTEM'

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

if [ "$ANTISPAM_SYSTEM" = 'rspamd' ] && dpkg -l rspamd 2> /dev/null | grep -q '^ii'; then
	echo "ERROR: rspamd is already installed."
	exit "$E_EXISTS"
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

echo "Installing rspamd (with Bayes Redis)..."
apt-get -y -qq install rspamd redis-server > /dev/null 2>&1
if ! dpkg -l rspamd 2> /dev/null | grep -q '^ii'; then
	echo "ERROR: rspamd installation failed."
	exit "$E_INVALID"
fi

# Redis: hard-capped Bayes companion unless it is the user's general service
if [ "${COMPONENT_DB_REDIS:-}" != "true" ] \
	&& ! grep -q 'HestiaRE rspamd-bayes limit' /etc/redis/redis.conf; then
	cat "$HESTIA/share/rspamd/redis-rspamd-limit.conf" >> /etc/redis/redis.conf
fi
systemctl enable redis-server > /dev/null 2>&1
systemctl restart redis-server 2> /dev/null || true

mkdir -p /etc/rspamd/local.d
cp -f "$HESTIA/share/rspamd/local.d/"* /etc/rspamd/local.d/

# Dedicated group for the controller socket (see worker-controller.inc). Its
# only purpose is reaching /run/rspamd/controller.sock. _rspamd joins it so the
# worker can chgrp its own socket to it — must exist before rspamd starts so
# the socket comes up with the right group. The Panel-Caddy PROXY is granted
# this group process-scoped (systemd drop-in below), not the caddy user, so app
# FPM pools running as caddy cannot inherit it (#341).
groupadd -r _rspamd-ctrl 2> /dev/null || true
usermod -aG _rspamd-ctrl _rspamd
# Heal pre-#341 installs: earlier versions added the caddy USER to _rspamd in
# /etc/group, which leaks controller access into the app FPM pools. Remove that
# stale membership — the proxy now gets _rspamd-ctrl process-scoped instead.
gpasswd -d caddy _rspamd > /dev/null 2>&1 || true
# Controller (stats/web UI) password. The in-panel UI never uses it —
# forward_auth + the secure unix-socket connection skip the rspamd login (see
# share/panel-caddy/apps/rspamd.tpl). It is set only so no known default
# password is active: both password (read) and enable_password (write) get
# the same random hash, overriding the stock worker-controller.inc "q1".
rspamd_pw=$(tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 24 || true)
rspamd_hash=$(rspamadm pw --password "$rspamd_pw")
printf 'password = "%s";\nenable_password = "%s";\n' "$rspamd_hash" "$rspamd_hash" \
	>> /etc/rspamd/local.d/worker-controller.inc
systemctl enable rspamd > /dev/null 2>&1
systemctl restart rspamd
if ! systemctl is-active --quiet rspamd; then
	echo "ERROR: rspamd failed to start."
	exit "$E_RESTART"
fi
# the workers create their unix sockets shortly after the unit is active — but a
# COLD first start (Lua compile, language detector, 120+ regexps, remote map
# fetches from maps.rspamd.com) legitimately takes far longer than a warm restart
# (~3s). Wait up to 60s so a slow first start does not abort the whole install.
for _ in $(seq 1 60); do
	[ -S /run/rspamd/normal.sock ] && [ -S /run/rspamd/controller.sock ] && break
	sleep 1
done
if [ ! -S /run/rspamd/normal.sock ]; then
	# The unit is active (checked above) — the socket is merely slow to bind on
	# this box. Do NOT abort the install for that: rspamd is running and the
	# socket materialises once the cold start finishes; the exim restart below
	# happens several steps later, and the smoke test verifies the socket
	# independently. Aborting here left mail installs half-wired (#353).
	echo "WARNING: rspamd scan worker socket not up after 60s — continuing (rspamd is active; smoke test will verify)."
fi

# Scan worker socket: Debian-exim (spam scan -> normal.sock) joins the _rspamd
# group so exim can reach it. This is a service account, not a shared web
# identity, so the /etc/group grant is fine here. Must precede the exim restart
# below so the running process picks up the membership.
usermod -aG _rspamd Debian-exim

# Controller socket: grant the Caddy PROXY process the _rspamd-ctrl group via a
# systemd drop-in (process-scoped), NOT the caddy user in /etc/group — app FPM
# pools also run as caddy and would otherwise inherit it through initgroups()
# and reach the controller past forward_auth (#341). caddy.service uses
# User=caddy, so systemd applies SupplementaryGroups to the process.
mkdir -p /etc/systemd/system/caddy.service.d
cp -f "$HESTIA/share/rspamd/caddy-service.d/rspamd-ctrl.conf" \
	/etc/systemd/system/caddy.service.d/rspamd-ctrl.conf
systemctl daemon-reload

# Publish the controller UI via Panel-Caddy — reached from the panel page
# /list/rspamd/ (iframe), gated behind the admin session. try-restart: only
# bounce Caddy if it is already running — on a fresh install it starts later
# (finalize stage, after daemon-reload here) and would fail without the panel
# SSL cert; either way it starts with the drop-in's group.
cp -f "$HESTIA/share/panel-caddy/apps/rspamd.tpl" /etc/caddy/apps/rspamd.conf
systemctl try-restart caddy 2> /dev/null || true

# Wire exim to rspamd: enable the RSPAMD/SPAM_SCORE macros in the active
# template (the .ifdef RSPAMD blocks are inert until this) and restart
sed -i -e 's/^#RSPAMD = yes/RSPAMD = yes/' \
	-e 's/^#SPAM_SCORE = /SPAM_SCORE = /' \
	-e 's/^#SPAM_REJECT_SCORE = /SPAM_REJECT_SCORE = /' \
	/etc/exim4/exim4.conf.template
systemctl restart exim4
if ! systemctl is-active --quiet exim4; then
	echo "ERROR: exim4 failed to restart with rspamd enabled."
	exit "$E_RESTART"
fi

$BIN/h-change-sys-config-value 'ANTISPAM_SYSTEM' 'rspamd'
set_install_component ADDON_RSPAMD true

echo "rspamd is now active (antispam system)."

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/h-log-action "system" "Info" "System" "Installed rspamd antispam."
log_event "$OK" "$ARGUMENTS"

exit
