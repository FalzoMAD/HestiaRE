#!/bin/bash
# info: update white label logo's
# options: [RESTORE] [RESET]
#
# example: h-update-white-label-logo
#
# Replace Hestia logos with user-created logos. With RESTORE=yes, missing
# custom files are restored from the shipped defaults ($HESTIA/web/images/
# default/ — pristine copies, since custom logos overwrite the live files);
# RESET=yes drops the custom set first. No external downloads (the upstream
# variant fetched HestiaCP logos from GitHub).

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
restore=${1-no}
reset=${2-no}

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source "$HESTIA/func/main.sh"
# load config file
source_conf "$HESTIA/conf/hestia.conf"

CUSTOM_DIR="$HESTIA/web/images/custom"
DEFAULT_DIR="$HESTIA/web/images/default"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

if [ "$reset" = "yes" ]; then
	rm -rf "$CUSTOM_DIR"
fi

# file -> live target
update_logo() {
	local file="$1"
	local target="$2"
	if [ -f "$CUSTOM_DIR/$file" ]; then
		cp -f "$CUSTOM_DIR/$file" "$target"
	elif [ "$restore" = "yes" ] && [ -f "$DEFAULT_DIR/$file" ]; then
		cp -f "$DEFAULT_DIR/$file" "$target"
	fi
}

update_logo "logo.svg" "$HESTIA/web/images/logo.svg"
update_logo "logo.png" "$HESTIA/web/images/logo.png"
update_logo "logo-header.svg" "$HESTIA/web/images/logo-header.svg"
update_logo "favicon.png" "$HESTIA/web/images/favicon.png"
update_logo "favicon.ico" "$HESTIA/web/favicon.ico"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

exit
