#!/bin/bash
# info: generate password hash
# options: HASH_METHOD SALT [PASSWORD]
#
# example: h-generate-password-hash sha-512 rAnDom_string yourPassWord
#
# Generates a crypt(3) password hash. HASH_METHOD is one of md5, sha-512,
# htpasswd, des. The password is taken from the 3rd argument or, if omitted,
# from stdin. Uses perl's crypt() (libc crypt(3)) — byte-identical to the
# previous PHP crypt() implementation, so existing hashes stay compatible.

method="$1"
salt="$2"

if [ -z "$method" ] || [ -z "$salt" ]; then
	echo "Error: not enough arguments" >&2
	echo "Usage: $0 HASH_METHOD SALT [PASSWORD]  (password may be sent on stdin)" >&2
	exit 1
fi

if [ -n "$3" ]; then
	password="$3"
else
	IFS= read -r password
fi

case "$method" in
	md5) setting="\$1\$${salt}\$" ;;
	sha-512) setting="\$6\$${salt}\$" ;;
	htpasswd) setting="$(printf '%s' "$password" | base64 -w0)" ;;
	des) setting="$salt" ;;
	*)
		echo "Error: HASH_METHOD must be one of 'md5', 'sha-512', 'htpasswd', 'des'" >&2
		exit 1
		;;
esac

# crypt() reads the algorithm + salt from the prefix of $setting, exactly like
# PHP's crypt() did ($1$/$6$ for md5/sha-512, a plain string for des/htpasswd).
perl -e 'print crypt($ARGV[0], $ARGV[1]), "\n"' "$password" "$setting"
