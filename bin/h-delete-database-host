#!/bin/bash
# info: delete database server
# options: TYPE HOST
#
# example: h-delete-database-host pgsql localhost
#
# This function for deleting the database host from hestia configuration. It will
# be deleted if there are no databases created on it only.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
type=$1
host=$2

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# shellcheck source=/usr/local/hestia/func/db.sh
source $HESTIA/func/db.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'TYPE HOST'
is_format_valid 'type' 'host'
is_system_enabled "$DB_SYSTEM" 'DB_SYSTEM'
is_type_valid "$DB_SYSTEM" "$type"
is_object_valid "$HESTIA/conf/$type" 'HOST' "$host"
is_dbhost_free

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Deleting server
sed -i "/HOST='$host' /d" "$HESTIA/conf/$type.conf"
# Delete RRD database
rm -fr $HESTIA'/web/rrd/db/'$type'_'$host'.rrd'
rm -fr $HESTIA'/web/rrd/db/'*-$type'_'$host'.*'

# Decompose DB_SYSTEM when the LAST host of this type is gone (counterpart to the
# compose in h-add-database-host). Without this the type stayed listed forever
# even after its last host was removed (#121), so the panel kept offering an
# engine with no host. Keep the token while any host of the type remains.
if ! grep -qs "HOST=" "$HESTIA/conf/$type.conf"; then
	rm -f "$HESTIA/conf/$type.conf"
	new_dbsys=$(echo "$DB_SYSTEM" | tr ',' '\n' | grep -vx "$type" | grep -v '^$' | paste -sd ',' -)
	$BIN/h-change-sys-config-value 'DB_SYSTEM' "$new_dbsys" > /dev/null 2>&1
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/h-log-action "system" "Info" "Database" "Removed remote database host (Host: $host, Type: $type)."
log_event "$OK" "$ARGUMENTS"

exit
