#!/bin/bash
# info: post-install smoke test (services, ports, logs)
# options: NONE
#
# example: h-check-sys-smoke
#
# Verifies that a fresh install came up: the services implied by the active
# configuration are running, the expected ports listen, the panel answers, and no
# critical markers are in the key logs. Preset-independent — it derives what to
# expect from hestia.conf's *_SYSTEM vars and install.conf's COMPONENT_* flags.
# Prints PASS/FAIL per check; exits 0 if all pass, 1 otherwise. No v-* symlink.

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
# live component state (COMPONENT_* flags), if present
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

pass=0
fail=0

ok() {
	echo "[ PASS ] $1"
	pass=$((pass + 1))
}
no() {
	echo "[ FAIL ] $1${2:+ — $2}"
	fail=$((fail + 1))
}
skip() { echo "[ skip ] $1"; }

# check_service <systemd-unit> <label>
check_service() {
	if systemctl is-active --quiet "$1"; then
		ok "service $2 ($1) active"
	else
		no "service $2 ($1) not active" "$(systemctl is-active "$1" 2> /dev/null)"
	fi
}

# check_port <port> <label>
check_port() {
	if ss -H -tln 2> /dev/null | awk '{print $4}' | grep -qE "[:.]$1\$"; then
		ok "port $1 ($2) listening"
	else
		no "port $1 ($2) not listening"
	fi
}

# check_socket <path> <label> — listening unix socket
check_socket() {
	if ss -H -xln 2> /dev/null | grep -qF "$1"; then
		ok "socket $2 ($1) listening"
	else
		no "socket $2 ($1) not listening"
	fi
}

# check_http <url> <label>
check_http() {
	local code
	code=$(curl -sk -o /dev/null -w '%{http_code}' --max-time 10 "$1" 2> /dev/null)
	if [ "$code" = "200" ]; then
		ok "$2 (HTTP $code)"
	else
		no "$2 (HTTP ${code:-000})"
	fi
}

# check_rspamd_ctrl_isolation — the #341 invariant: the rspamd controller
# socket is reachable by the Caddy PROXY process but NOT by the app FPM pools
# that share the caddy user. Verified against process credentials + /etc/group,
# not config, so a regression (e.g. re-adding `usermod -aG _rspamd caddy`)
# fails here. Catches the whole "socket grant leaks into the wrong role" class.
check_rspamd_ctrl_isolation() {
	local gid pid pgroups
	gid=$(getent group _rspamd-ctrl | cut -d: -f3)
	if [ -z "$gid" ]; then
		no "rspamd controller group _rspamd-ctrl missing"
		return
	fi
	# 1. socket carries the dedicated group (not plain _rspamd)
	if [ "$(stat -c '%G' /run/rspamd/controller.sock 2> /dev/null)" = '_rspamd-ctrl' ]; then
		ok "controller socket group is _rspamd-ctrl"
	else
		no "controller socket not group _rspamd-ctrl" "$(stat -c '%G' /run/rspamd/controller.sock 2> /dev/null)"
	fi
	# 2. the caddy USER must NOT be in the controller group (nor _rspamd) in
	#    /etc/group — otherwise app pools inherit it via initgroups()
	if id -nG caddy 2> /dev/null | tr ' ' '\n' | grep -qxE '_rspamd(-ctrl)?'; then
		no "caddy user is in an rspamd group (app pools would inherit socket access)" "$(id -nG caddy)"
	else
		ok "caddy user not in any rspamd group (app pools isolated)"
	fi
	# 3. the caddy PROXY process must actually hold the group (else UI breaks)
	pid=$(systemctl show -p MainPID --value caddy.service 2> /dev/null)
	pgroups=$(grep -E '^Groups:' /proc/"${pid:-0}"/status 2> /dev/null)
	if echo "$pgroups" | tr ' \t' '\n' | grep -qx "$gid"; then
		ok "caddy proxy process holds _rspamd-ctrl (controller reachable)"
	else
		no "caddy proxy process lacks _rspamd-ctrl (controller UI would break)" "$pgroups"
	fi
}

# check_log_clean <file> <extended-regex> <label>
check_log_clean() {
	if [ ! -f "$1" ]; then
		skip "log $2 absent ($1)"
		return
	fi
	local hits
	hits=$(grep -aEc "$2" "$1" 2> /dev/null || true)
	if [ "${hits:-0}" -eq 0 ]; then
		ok "log $3 clean"
	else
		no "log $3 has $hits critical entr$([ "$hits" -eq 1 ] && echo y || echo ies)" "$1"
	fi
}

# check_file_empty <file> <label>  (fail if file exists and is non-empty)
check_file_empty() {
	if [ -s "$1" ]; then
		no "$2 non-empty" "$1"
	else
		ok "$2 empty/absent"
	fi
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

echo "=== HestiaRE smoke test ==="

# --- Panel (always expected) ---
echo "-- panel --"
check_service caddy "panel webserver"
check_service hestia-php "panel PHP-FPM"
check_port "${BACKEND_PORT:-8083}" "panel"
check_http "https://127.0.0.1:${BACKEND_PORT:-8083}/login/" "panel login page"

# --- Configured subsystems (derived from *_SYSTEM) ---
echo "-- services --"
[ -n "$WEB_SYSTEM" ] && [ "$WEB_SYSTEM" != 'nginx' ] && check_service "$WEB_SYSTEM" "web"
[ -n "$PROXY_SYSTEM" ] && [ "$PROXY_SYSTEM" != 'remote' ] && check_service "$PROXY_SYSTEM" "reverse proxy"
[ -n "$MAIL_SYSTEM" ] && [ "$MAIL_SYSTEM" != 'remote' ] && check_service "$MAIL_SYSTEM" "mail"
[ -n "$IMAP_SYSTEM" ] && [ "$IMAP_SYSTEM" != 'remote' ] && check_service "$IMAP_SYSTEM" "imap"
[ -n "$ANTISPAM_SYSTEM" ] && [ "$ANTISPAM_SYSTEM" != 'remote' ] && check_service "$ANTISPAM_SYSTEM" "antispam"
[ -n "$FTP_SYSTEM" ] && [ "$FTP_SYSTEM" != 'remote' ] && check_service "$FTP_SYSTEM" "ftp"
[ -n "$CRON_SYSTEM" ] && check_service "$CRON_SYSTEM" "cron"
is_on() { [ "${1:-}" = "true" ] || [ "${1:-}" = "yes" ]; }
if echo "$DB_SYSTEM" | grep -qw 'mysql'; then check_service mariadb "database (mysql)"; fi
# PostgreSQL: selected as an optional engine (COMPONENT_DB_POSTGRESQL), which does
# NOT write 'pgsql' into DB_SYSTEM — so keying off DB_SYSTEM alone missed it
# entirely. Honour the component flag (and DB_SYSTEM for forward-compat).
if echo "$DB_SYSTEM" | grep -qw 'pgsql' || is_on "${COMPONENT_DB_POSTGRESQL:-}"; then
	check_service postgresql "database (pgsql)"
fi
# Optional addons (only if the install recipe enabled them)
is_on "${COMPONENT_ADDON_FAIL2BAN:-}" && check_service fail2ban "fail2ban"
is_on "${COMPONENT_ADDON_CLAMAV:-}" && check_service clamav-daemon "clamav"
# Redis: either the user's DB choice (DB_REDIS) or rspamd's always-present
# Bayes companion (hard-capped, see share/rspamd/redis-rspamd-limit.conf).
if is_on "${COMPONENT_DB_REDIS:-}" || [ "$ANTISPAM_SYSTEM" = 'rspamd' ]; then
	check_service redis-server "redis"
fi

# --- Ports implied by the active config ---
echo "-- ports --"
if [ -n "$PROXY_SYSTEM" ] || [ -n "$WEB_SYSTEM" ]; then
	check_port 80 "http"
	check_port 443 "https"
fi
echo "$DB_SYSTEM" | grep -qw 'mysql' && check_port 3306 "mysql"
[ -n "$MAIL_SYSTEM" ] && [ "$MAIL_SYSTEM" != 'remote' ] && check_port 25 "smtp"
if [ "$ANTISPAM_SYSTEM" = 'rspamd' ]; then
	# group-restricted unix sockets since #301/#321 — rspamd has no TCP ports
	check_socket /run/rspamd/normal.sock "rspamd scan worker"
	check_socket /run/rspamd/controller.sock "rspamd controller"
	check_rspamd_ctrl_isolation
fi
# localhost consumers only (webmail plugin) — not opened in the firewall
[ "$SIEVE_SYSTEM" = 'yes' ] && check_port 4190 "managesieve"

# --- Critical log markers ---
echo "-- logs --"
check_log_clean "/var/log/hestia-php-fpm.log" "PHP (Fatal|Parse) error|\[emergency\]|\[alert\]" "panel FPM"
[ -n "$PROXY_SYSTEM" ] && check_log_clean "/var/log/nginx/error.log" "\[emerg\]|\[alert\]" "nginx"
[ "$WEB_SYSTEM" = 'apache2' ] && check_log_clean "/var/log/apache2/error.log" "\[.*:emerg\]|\[.*:alert\]" "apache2"
# exim writes serious problems to a dedicated paniclog — non-empty means trouble
[ -n "$MAIL_SYSTEM" ] && [ "$MAIL_SYSTEM" != 'remote' ] && check_file_empty "/var/log/exim4/paniclog" "exim paniclog"

#----------------------------------------------------------#
#                       Result                             #
#----------------------------------------------------------#

echo "=== result: $pass passed, $fail failed ==="
if [ "$fail" -gt 0 ]; then
	exit 1
fi
exit 0
