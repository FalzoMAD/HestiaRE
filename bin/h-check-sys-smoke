#!/bin/bash
# info: post-install smoke test (services, ports, logs)
# options: NONE
#
# example: h-check-sys-smoke
#
# Verifies that a fresh install came up: the services implied by the active
# configuration are running, the expected ports listen, the panel answers, and no
# critical markers are in the key logs. Preset-independent — it derives what to
# expect from hestia.conf's *_SYSTEM vars and install.conf's COMPONENT_* flags.
# Prints PASS/FAIL per check; exits 0 if all pass, 1 otherwise. No v-* symlink.

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
# live component state (COMPONENT_* flags), if present
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

pass=0
fail=0

ok() {
	echo "[ PASS ] $1"
	pass=$((pass + 1))
}
no() {
	echo "[ FAIL ] $1${2:+ — $2}"
	fail=$((fail + 1))
}
skip() { echo "[ skip ] $1"; }

# check_source_absent <label> <pattern> <path...> — a vulnerable pattern must not
# reappear (static regression guard for a security fix). Comment lines excluded.
check_source_absent() {
	local label="$1" pat="$2"
	shift 2
	local hit
	hit=$(grep -rnE "$pat" "$@" 2> /dev/null | grep -vE ':[[:space:]]*(//|#|\*)')
	if [ -z "$hit" ]; then
		ok "invariant: $label"
	else
		no "invariant: $label" "$(echo "$hit" | head -n1)"
	fi
}

# check_service <systemd-unit> <label>
check_service() {
	if systemctl is-active --quiet "$1"; then
		ok "service $2 ($1) active"
	else
		no "service $2 ($1) not active" "$(systemctl is-active "$1" 2> /dev/null)"
	fi
}

# check_port <port> <label>
check_port() {
	if ss -H -tln 2> /dev/null | awk '{print $4}' | grep -qE "[:.]$1\$"; then
		ok "port $1 ($2) listening"
	else
		no "port $1 ($2) not listening"
	fi
}

# check_socket <path> <label> — listening unix socket
check_socket() {
	if ss -H -xln 2> /dev/null | grep -qF "$1"; then
		ok "socket $2 ($1) listening"
	else
		no "socket $2 ($1) not listening"
	fi
}

# check_http <url> <label>
check_http() {
	local code
	code=$(curl -sk -o /dev/null -w '%{http_code}' --max-time 10 "$1" 2> /dev/null)
	if [ "$code" = "200" ]; then
		ok "$2 (HTTP $code)"
	else
		no "$2 (HTTP ${code:-000})"
	fi
}

# check_rspamd_ctrl_isolation — the controller socket must be reachable by the
# Caddy proxy process but NOT by the app FPM pools that share the caddy user.
# Checked against live process creds + /etc/group, so a config regression fails here.
check_rspamd_ctrl_isolation() {
	local gid pid pgroups
	gid=$(getent group _rspamd-ctrl | cut -d: -f3)
	if [ -z "$gid" ]; then
		no "rspamd controller group _rspamd-ctrl missing"
		return
	fi
	# 1. socket carries the dedicated group (not plain _rspamd)
	if [ "$(stat -c '%G' /run/rspamd/controller.sock 2> /dev/null)" = '_rspamd-ctrl' ]; then
		ok "controller socket group is _rspamd-ctrl"
	else
		no "controller socket not group _rspamd-ctrl" "$(stat -c '%G' /run/rspamd/controller.sock 2> /dev/null)"
	fi
	# 2. caddy user NOT in the controller group (else app pools inherit via initgroups)
	if id -nG caddy 2> /dev/null | tr ' ' '\n' | grep -qxE '_rspamd(-ctrl)?'; then
		no "caddy user is in an rspamd group (app pools would inherit socket access)" "$(id -nG caddy)"
	else
		ok "caddy user not in any rspamd group (app pools isolated)"
	fi
	# 3. caddy proxy process DOES hold the group (else controller UI breaks)
	pid=$(systemctl show -p MainPID --value caddy.service 2> /dev/null)
	pgroups=$(grep -E '^Groups:' /proc/"${pid:-0}"/status 2> /dev/null)
	if echo "$pgroups" | tr ' \t' '\n' | grep -qx "$gid"; then
		ok "caddy proxy process holds _rspamd-ctrl (controller reachable)"
	else
		no "caddy proxy process lacks _rspamd-ctrl (controller UI would break)" "$pgroups"
	fi
}

# check_log_clean <file> <extended-regex> <label>
check_log_clean() {
	if [ ! -f "$1" ]; then
		skip "log $2 absent ($1)"
		return
	fi
	local hits
	hits=$(grep -aEc "$2" "$1" 2> /dev/null || true)
	if [ "${hits:-0}" -eq 0 ]; then
		ok "log $3 clean"
	else
		no "log $3 has $hits critical entr$([ "$hits" -eq 1 ] && echo y || echo ies)" "$1"
	fi
}

# check_file_empty <file> <label>  (fail if file exists and is non-empty)
check_file_empty() {
	if [ -s "$1" ]; then
		no "$2 non-empty" "$1"
	else
		ok "$2 empty/absent"
	fi
}

# check_banner <port> <label> — service answers with a protocol banner in 5s.
# Catches "active + listening but dead" (e.g. dovecot IMAP login hangs) that
# check_service/check_port miss.
check_banner() {
	local banner
	# head -n1, NOT head -c N: a byte-count read blocks until N bytes arrive
	banner=$(timeout 5 bash -c "exec 3<>/dev/tcp/127.0.0.1/$1 && head -n1 <&3" 2> /dev/null)
	if [ -n "$banner" ]; then
		ok "port $1 ($2) answers with a banner"
	else
		no "port $1 ($2) gave no banner within 5s (service up but not functional?)"
	fi
}

# check_v_symlinks_resolve — no v-* compat alias may dangle (catches a rename/
# removal the install-time prune should have cleared). Extra aliases are fine.
check_v_symlinks_resolve() {
	local dangling first
	dangling=$(find "$HESTIA/bin" -maxdepth 1 -name 'v-*' -xtype l 2> /dev/null)
	if [ -z "$dangling" ]; then
		ok "no dangling v-* symlinks"
	else
		no "dangling v-* symlink(s)" "$(echo "$dangling" | head -n1 | xargs basename)"
	fi
}

# check_info_headers — every h-* command must keep a non-empty `# info:` line
# (Hestia parses it for --help/usage; a comment sweep must not eat it).
check_info_headers() {
	local f n miss=0 first=""
	for f in "$HESTIA/bin"/h-*; do
		[ -f "$f" ] || continue
		n=$(sed -n 's/^# info:[[:space:]]*//p' "$f" | head -n1)
		if [ -z "$n" ]; then
			miss=$((miss + 1))
			[ -z "$first" ] && first="$(basename "$f")"
		fi
	done
	if [ "$miss" -eq 0 ]; then
		ok "all h-* commands have a # info: line"
	else
		no "$miss h-* command(s) missing a # info: line" "$first"
	fi
}

# check_sudoers <file> <label> — file parses under the running sudo. One rejected
# setting (e.g. requiretty under sudo-rs, ub26) makes sudo drop the WHOLE file.
check_sudoers() {
	if [ ! -f "$1" ]; then
		no "sudoers $2 ($1) missing"
		return
	fi
	if visudo -cf "$1" > /dev/null 2>&1; then
		ok "sudoers $2 ($1) valid"
	else
		no "sudoers $2 ($1) invalid" "$(visudo -cf "$1" 2>&1 | tail -1)"
	fi
}

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

echo "=== HestiaRE smoke test ==="

# --- Panel (always expected) ---
echo "-- panel --"
check_service caddy "panel webserver"
check_service hestia-php "panel PHP-FPM"
check_port "${BACKEND_PORT:-8083}" "panel"
check_http "https://127.0.0.1:${BACKEND_PORT:-8083}/login/" "panel login page"
# invalid sudoers → no privileged panel action works
check_sudoers /etc/sudoers.d/hestia "hestia grant"

# --- Configured subsystems (derived from *_SYSTEM) ---
echo "-- services --"
[ -n "$WEB_SYSTEM" ] && [ "$WEB_SYSTEM" != 'nginx' ] && check_service "$WEB_SYSTEM" "web"
[ -n "$PROXY_SYSTEM" ] && [ "$PROXY_SYSTEM" != 'remote' ] && check_service "$PROXY_SYSTEM" "reverse proxy"
[ -n "$MAIL_SYSTEM" ] && [ "$MAIL_SYSTEM" != 'remote' ] && check_service "$MAIL_SYSTEM" "mail"
[ -n "$IMAP_SYSTEM" ] && [ "$IMAP_SYSTEM" != 'remote' ] && check_service "$IMAP_SYSTEM" "imap"
[ -n "$ANTISPAM_SYSTEM" ] && [ "$ANTISPAM_SYSTEM" != 'remote' ] && check_service "$ANTISPAM_SYSTEM" "antispam"
[ -n "$FTP_SYSTEM" ] && [ "$FTP_SYSTEM" != 'remote' ] && check_service "$FTP_SYSTEM" "ftp"
[ -n "$CRON_SYSTEM" ] && check_service "$CRON_SYSTEM" "cron"
is_on() { [ "${1:-}" = "true" ] || [ "${1:-}" = "yes" ]; }
if echo "$DB_SYSTEM" | grep -qw 'mysql'; then check_service mariadb "database (mysql)"; fi
# postgres flag does NOT write 'pgsql' into DB_SYSTEM → key off the component flag too
if echo "$DB_SYSTEM" | grep -qw 'pgsql' || is_on "${COMPONENT_DB_POSTGRESQL:-}"; then
	check_service postgresql "database (pgsql)"
fi
is_on "${COMPONENT_ADDON_FAIL2BAN:-}" && check_service fail2ban "fail2ban"
is_on "${COMPONENT_ADDON_CLAMAV:-}" && check_service clamav-daemon "clamav"
# adminer/webmail: no own daemon — served by a caddy FPM pool, so check the socket
is_on "${COMPONENT_ADDON_ADMINER:-}" && check_socket /run/hestia-adminer.sock "adminer FPM"
if echo "$WEBMAIL_SYSTEM" | grep -qw 'roundcube'; then
	check_socket /run/hestia-webmail-rc.sock "roundcube FPM"
	check_http "http://127.0.0.1:8090/" "roundcube internal listener"
fi
if echo "$WEBMAIL_SYSTEM" | grep -qw 'snappymail'; then
	check_socket /run/hestia-webmail-sm.sock "snappymail FPM"
	check_http "http://127.0.0.1:8091/" "snappymail internal listener"
fi
# redis: user's DB choice or rspamd's always-present Bayes companion
if is_on "${COMPONENT_DB_REDIS:-}" || [ "$ANTISPAM_SYSTEM" = 'rspamd' ]; then
	check_service redis-server "redis"
fi

# --- Ports implied by the active config ---
echo "-- ports --"
if [ -n "$PROXY_SYSTEM" ] || [ -n "$WEB_SYSTEM" ]; then
	check_port 80 "http"
	check_port 443 "https"
fi
echo "$DB_SYSTEM" | grep -qw 'mysql' && check_port 3306 "mysql"
[ -n "$MAIL_SYSTEM" ] && [ "$MAIL_SYSTEM" != 'remote' ] && check_port 25 "smtp"
# banner, not just port: IMAP/SMTP must actually answer (a hung login still listens)
if [ -n "$IMAP_SYSTEM" ] && [ "$IMAP_SYSTEM" != 'remote' ]; then
	check_banner 143 "imap"
fi
[ -n "$MAIL_SYSTEM" ] && [ "$MAIL_SYSTEM" != 'remote' ] && check_banner 25 "smtp"
if [ "$ANTISPAM_SYSTEM" = 'rspamd' ]; then
	# group-restricted unix sockets — rspamd has no TCP ports
	check_socket /run/rspamd/normal.sock "rspamd scan worker"
	check_socket /run/rspamd/controller.sock "rspamd controller"
	check_rspamd_ctrl_isolation
fi
# localhost-only (webmail managesieve plugin), not opened in the firewall
[ "$SIEVE_SYSTEM" = 'yes' ] && check_port 4190 "managesieve"

# --- Critical log markers ---
echo "-- logs --"
check_log_clean "/var/log/hestia-php-fpm.log" "PHP (Fatal|Parse) error|\[emergency\]|\[alert\]" "panel FPM"
[ -n "$PROXY_SYSTEM" ] && check_log_clean "/var/log/nginx/error.log" "\[emerg\]|\[alert\]" "nginx"
[ "$WEB_SYSTEM" = 'apache2' ] && check_log_clean "/var/log/apache2/error.log" "\[.*:emerg\]|\[.*:alert\]" "apache2"
# exim writes serious problems to a dedicated paniclog — non-empty means trouble
[ -n "$MAIL_SYSTEM" ] && [ "$MAIL_SYSTEM" != 'remote' ] && check_file_empty "/var/log/exim4/paniclog" "exim paniclog"

# --- Security invariants (static source gates) ---
echo "-- security invariants --"
# GHSA-fcq6: auth gate must not compare a bare $ROOT_USER (legit: $_SESSION["ROOT_USER"])
check_source_absent "no bare \$ROOT_USER auth gate (GHSA-fcq6)" '\$ROOT_USER' "$HESTIA/web"
# GHSA-cr7q: search-object commands must not eval raw conf-field payloads
check_source_absent "no raw eval in search-object (GHSA-cr7q)" '(^|[^_])eval[[:space:]]' \
	"$HESTIA/bin/h-search-user-object" "$HESTIA/bin/h-search-object"
# v-* compat symlinks must all resolve (no dangling alias left by a rename).
check_v_symlinks_resolve
# every h-* keeps its parsed # info: line (a comment sweep must not eat it).
check_info_headers

#----------------------------------------------------------#
#                       Result                             #
#----------------------------------------------------------#

echo "=== result: $pass passed, $fail failed ==="
if [ "$fail" -gt 0 ]; then
	exit 1
fi
exit 0
