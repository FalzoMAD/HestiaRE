#!/bin/bash
# info: disables support for single sign on phpMyAdmin
# options: [mode]
#
# example: h-delete-sys-pma-sso
#
# Disables support for SSO to phpMyAdmin

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

MODE=$1

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

PMA_INSTALL="/usr/share/phpmyadmin"
PMA_CONFIG="/etc/phpmyadmin"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

if [ "$(id -u)" != '0' ]; then
	echo "Error: Script can be run executed only by root"
	exit 10
fi

if [ ! -f "$PMA_INSTALL/hestia-sso.php" ]; then
	echo 'Error: PMA Single Sign On already disabled'
	exit 1
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Revoke API key
apikey=$(grep -Po "'API_KEY', '(.*)'" "$PMA_INSTALL/hestia-sso.php" | cut -d"'" -f4)
if [ -n "$apikey" ]; then
	if echo "$apikey" | grep -q ":"; then
		apikey=$(echo "$apikey" | cut -d: -f1)
		$BIN/h-delete-access-key "$apikey" 2>/dev/null || true
	else
		$BIN/h-revoke-api-key "$apikey" 2>/dev/null || true
	fi
fi

# Remove SSO files
rm -f "$PMA_INSTALL/hestia-sso.php"
rm -f "$PMA_CONFIG/conf.d/hestia-sso.inc.php"

# Disable key
$BIN/h-change-sys-config-value 'PHPMYADMIN_KEY' ""

#----------------------------------------------------------#
#                       Logging                            #
#----------------------------------------------------------#

if [ "$MODE" != "quiet" ]; then
	echo "PMA Hestia-SSO plugin has been successfully removed/disabled"
fi
$BIN/h-log-action "system" "Info" "Plugins" "phpMyAdmin Single Sign-On (SSO) disabled."
log_event "$OK" "$ARGUMENTS"
