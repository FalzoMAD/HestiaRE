#!/bin/bash
# info: update mail templates
# options: [RESTART] [SKIP]
#
# example: h-update-mail-templates
#
# This function for obtaining updated webmail templates from Hestia package.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
restart=$1
skip=$2

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

check_args '1' "$#" '[RESTART]' '[SKIP]'
is_format_valid 'restart'

# Mail templates ship at $HESTIA/templates/mail (delivered by the tarball) —
# there is no separate install source to copy from anymore.
# Rebuild mail domains if mail services are enabled
if [ -z "$skip" ]; then
	if [ -n "$MAIL_SYSTEM" ]; then
		for user in $("$BIN/h-list-users" list); do
			$BIN/h-rebuild-mail-domains "$user" no
		done
	fi
fi
#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

if [ -n "$restart" ] || [ "$restart" == "yes" ]; then
	# Restarting web server
	$BIN/h-restart-web "$restart"
	check_result $? "restart" > /dev/null 2>&1

	$BIN/h-restart-proxy "$restart"
	check_result $? "restart" > /dev/null 2>&1
fi
$BIN/h-log-action "system" "Info" "Updates" "Default mail domain templates updated."
exit
