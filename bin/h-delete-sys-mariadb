#!/bin/bash
# info: remove MariaDB database server
# options: NONE
#
# example: h-delete-sys-mariadb
#
# Counterpart to h-add-sys-mariadb. Refuses while the local host still carries
# customer DBs (counter + live SHOW DATABASES cross-check). Datadir /var/lib/mysql
# is kept by default; phpMyAdmin (+SSO) is torn down first.
# Opt-ins: FORCE=yes skips the customer-DB check; PURGE_DATA=yes also wipes the datadir.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

if [ "x$(id -u)" != 'x0' ]; then
	echo "Error: Script can be run executed only by root"
	exit 10
fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

# Not installed?
if ! dpkg -l mariadb-server 2> /dev/null | grep -q '^ii'; then
	echo "ERROR: MariaDB is not installed."
	exit "$E_NOTEXIST"
fi

# refuse while customer DBs exist (unless FORCE=yes): counter, then a live check
if [ "${FORCE:-}" != "yes" ]; then
	u_db_bases=$(grep -o "U_DB_BASES='[0-9]*'" "$HESTIA/conf/mysql.conf" 2> /dev/null | grep -o '[0-9]*' | head -1)
	live_db=0
	if [ -f /root/.my.cnf ]; then
		# exclude system schemas AND app-owned DBs (pma/roundcube/snappymail) — keep
		# this safelist in sync if a new bundled app grows its own MySQL DB
		live_db=$(mariadb -N -e "SHOW DATABASES;" 2> /dev/null \
			| grep -vxE 'information_schema|performance_schema|mysql|sys|phpmyadmin|roundcube|snappymail' \
			| grep -c .)
		live_db=${live_db:-0}
	fi
	if [ "${u_db_bases:-0}" != "0" ] || [ "${live_db:-0}" != "0" ]; then
		echo "ERROR: MariaDB still hosts customer databases (counter=${u_db_bases:-0}, live=${live_db:-0})."
		echo "       Delete them first, or re-run with FORCE=yes."
		exit "$E_INUSE"
	fi
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# phpMyAdmin (SSO before the app), then deregister the host (strips DB_SYSTEM's mysql token)
$BIN/h-delete-sys-pma-sso > /dev/null 2>&1 || true
$BIN/h-delete-sys-phpmyadmin > /dev/null 2>&1 || true
$BIN/h-delete-database-host mysql localhost > /dev/null 2>&1 || true

# purge packages (no autoremove — it would rip out shared-stack siblings)
echo "[ * ] Removing MariaDB packages..."
systemctl disable --now mariadb > /dev/null 2>&1 || true
DEBIAN_FRONTEND=noninteractive apt-get -y -qq purge \
	mariadb-server mariadb-client mariadb-common > /dev/null 2>&1 || true

# external repo cleanup (harmless on an OS-package install)
rm -f /etc/apt/sources.list.d/mariadb.list /usr/share/keyrings/mariadb-keyring.gpg
rm -f /root/.my.cnf

# datadir kept by default so a re-add finds the DBs; opt-in wipe
if [ "${PURGE_DATA:-}" = "yes" ]; then
	echo "[ * ] PURGE_DATA=yes — wiping /var/lib/mysql..."
	rm -rf /var/lib/mysql
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

set_install_component DB_MARIADB false
# no engine, no version
set_install_component DB_MARIADB_VERSION ""
$BIN/h-change-sys-config-value 'DB_PMA_ALIAS' '' > /dev/null 2>&1 || true

echo "[ OK ] MariaDB removed.$([ "${PURGE_DATA:-}" = "yes" ] && echo '' || echo ' (datadir kept — PURGE_DATA=yes to wipe)')"

$BIN/h-log-action "system" "Info" "System" "MariaDB removed."
log_event "$OK" "$ARGUMENTS"

exit
