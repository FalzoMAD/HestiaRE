#!/bin/bash
# info: enables support for single sign on phpMyAdmin
# options: [mode]
#
# example: h-add-sys-pma-sso
#
# This function enables support for SSO to phpMyAdmin

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

MODE=$1

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

PMA_INSTALL="/usr/share/phpmyadmin"
PMA_CONFIG="/etc/phpmyadmin"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

if [ "$(id -u)" != '0' ]; then
	echo "Error: Script can be run executed only by root"
	exit 10
fi

if [ -n "$PHPMYADMIN_KEY" ] && [ "$PHPMYADMIN_KEY" != "" ]; then
	echo "Error: SSO has been installed before. To re-enable it run h-delete-sys-pma-sso first"
	exit 1
fi

if [ -f "$PMA_INSTALL/hestia-sso.php" ]; then
	echo "Error: hestia-sso.php is already installed"
	exit 2
fi

if [ ! -f "/usr/local/hestia/web/api/index.php" ]; then
	echo "Error: API script not installed"
	exit 2
fi

if [ "$API_SYSTEM" = "0" ]; then
	echo "Error: API is not enabled"
	exit 2
fi

if [ ! -f "$PMA_CONFIG/config-db.php" ]; then
	echo "Error: phpMyAdmin not configured. Run h-add-sys-phpmyadmin first"
	exit 2
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Generate the keys to secure everything
phpmyadminkey=$(generate_password)
apikey=$($BIN/h-add-access-key "$ROOT_USER" 'phpmyadmin-sso' 'phpMyAdmin' 'plain')

# Deploy hestia-sso.php into the PMA webroot
cp -f $HESTIA_INSTALL_DIR/phpmyadmin/hestia-sso.php $PMA_INSTALL/hestia-sso.php
chmod 640 $PMA_INSTALL/hestia-sso.php
chown root:caddy $PMA_INSTALL/hestia-sso.php

sed -i "s/%PHPMYADMIN_KEY%/$phpmyadminkey/g" $PMA_INSTALL/hestia-sso.php
sed -i "s/%API_KEY%/$apikey/g" $PMA_INSTALL/hestia-sso.php
sed -i "s/%API_HOST_NAME%/$(hostname -f)/g" $PMA_INSTALL/hestia-sso.php
sed -i "s/%API_HESTIA_PORT%/$BACKEND_PORT/g" $PMA_INSTALL/hestia-sso.php

# Write SSO config into conf.d — loaded by OS package config.inc.php glob.
# Uses $cfg['Servers'][1] directly (not $i): the OS config.inc.php increments
# $i twice before the conf.d glob runs (once on init, once after config-db.php),
# so $i would equal 2 at that point — not the active server slot.
# BRITTLE RISK: if a phpMyAdmin package update restructures config.inc.php and
# changes the number of $i increments before the glob, this hardcoded [1] will
# silently misconfigure SSO (auth_type switches but targets the wrong server).
# To verify after a PMA upgrade: count $i increments in
# /etc/phpmyadmin/config.inc.php above the "foreach glob(...conf.d...)" line —
# if the count changes from 2, update [1] here accordingly.
mkdir -p "$PMA_CONFIG/conf.d"
cat > "$PMA_CONFIG/conf.d/hestia-sso.inc.php" <<'PHP'
<?php
if (isset($_GET['hestia_token']) || isset($_COOKIE['SignonSession'])) {
    $cfg['Servers'][1]['auth_type'] = 'signon';
    $cfg['Servers'][1]['SignonSession'] = 'SignonSession';
    $cfg['Servers'][1]['SignonURL'] = 'hestia-sso.php';
    $cfg['Servers'][1]['LogoutURL'] = 'hestia-sso.php?logout=1';
}
PHP
chmod 640 "$PMA_CONFIG/conf.d/hestia-sso.inc.php"
chown root:www-data "$PMA_CONFIG/conf.d/hestia-sso.inc.php"

$BIN/h-change-sys-config-value 'PHPMYADMIN_KEY' "$phpmyadminkey"

if ! echo "$API_ALLOWED_IP" | grep -q "127.0.0.1"; then
	$BIN/h-add-sys-api-ip "127.0.0.1"
fi

#----------------------------------------------------------#
#                       Logging                            #
#----------------------------------------------------------#

if [ "$MODE" != "quiet" ]; then
	echo "PMA Hestia-SSO plugin has been successfully installed"
fi
$BIN/h-log-action "system" "Info" "Plugins" "phpMyAdmin Single Sign-On has been enabled."
log_event "$OK" "$ARGUMENTS"
