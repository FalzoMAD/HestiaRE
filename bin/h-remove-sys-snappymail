#!/bin/bash
# info: Delete SnappyMail webmail client
# options: None
#
# This function removes the SnappyMail webmail client.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
# live component state (COMPONENT_MAIL_WEBMAILER), if present
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"

# Folder paths
SM_INSTALL_DIR="/var/lib/snappymail"
SM_CONFIG_DIR="/etc/snappymail"
SM_LOG="/var/log/snappymail"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Checking root permissions
if [ "x$(id -u)" != 'x0' ]; then
	echo "ERROR: h-remove-sys-snappymail can only be executed by the root user"
	exit 10
fi

# Ensure that $HESTIA (/usr/local/hestia/) and other variables are valid.
if [ -z "$HESTIA" ]; then
	HESTIA="/usr/local/hestia"
fi

if [ -z "$HOMEDIR" ] || [ -z "$HESTIA_INSTALL_DIR" ]; then
	echo "ERROR: Environment variables not present, uninstallation aborted."
	exit 2
fi

if [ -z "$(echo "$DB_SYSTEM" | grep -w 'mysql')" ]; then
	echo "ERROR: Mysql not available. Uninstallation aborted"
	exit 2
fi

# Get current version
if [ -f "/var/lib/snappymail/data/VERSION" ]; then
	version=$(cat /var/lib/snappymail/data/VERSION)
else
	echo "Error: SnappyMail is not installed"
	exit 2
fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Panel-Caddy delivery teardown (#205): internal listener + FPM pool first, so
# nothing serves from the dirs we are about to delete.
rm -f /etc/caddy/webmail-snappymail.conf
systemctl try-restart caddy > /dev/null 2>&1 || true
rm -f /etc/php/hestia/fpm/pool.d/snappymail.conf
systemctl reload hestia-php 2> /dev/null || systemctl restart hestia-php 2> /dev/null || true

rm -f -r $SM_INSTALL_DIR
rm -f -r $SM_CONFIG_DIR
rm ~/.snappymail

if [ -f '/usr/bin/mariadb' ]; then
	mariadb -e "DROP DATABASE snappymail" 2>&1
	mariadb -e "DROP USER snappymail@localhost"
else
	mysql -e "DROP DATABASE snappymail" 2>&1
	mysql -e "DROP USER snappymail@localhost"
fi
# Updating hestia.conf — remove snappymail from the WEBMAIL_SYSTEM list. The old
# guard here was inverted ([ -z ... ]: only rewrote when snappymail was ABSENT),
# so a normal removal never cleared the entry (#234). Token-based strip instead
# of sed, so no stray commas survive in any position.
if echo "$WEBMAIL_SYSTEM" | grep -qw 'snappymail'; then
	new_webmail=$(echo "$WEBMAIL_SYSTEM" | tr ',' '\n' | grep -vx 'snappymail' | grep -v '^$' | paste -sd ',' -)
	$BIN/h-change-sys-config-value 'WEBMAIL_SYSTEM' "$new_webmail"
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Reset the wizard selection only if SnappyMail was the recorded webmailer —
# removing a secondary client must not clobber another one's selection (#234).
if [ "${COMPONENT_MAIL_WEBMAILER:-}" = "SNAPPYMAIL" ]; then
	set_install_component MAIL_WEBMAILER NONE
fi

$BIN/h-log-action "system" "Info" "Plugins" "SnappyMail removed (Version: $version)."

log_event "$OK" "$ARGUMENTS"
