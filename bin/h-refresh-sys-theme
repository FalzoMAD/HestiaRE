#!/bin/bash
# info: change active system theme
# options: NONE
#
# example: h-refresh-sys-theme
#
# This function for changing the currently active system theme.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Store current theme name
CURRENT_THEME=$THEME

# Cycle theme to regenerate (helps if cache is stuck)
$BIN/h-change-sys-theme "default"
$BIN/h-change-sys-theme "$CURRENT_THEME"
