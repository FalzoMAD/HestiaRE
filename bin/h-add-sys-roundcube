#!/bin/bash
# info: Install Roundcube webmail client
# options: NONE
#
# This function installs Roundcube from OS repositories, sets up a
# dedicated MySQL database, deploys the HestiaRE password driver, and
# configures panel integration.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

RC_CONFIG_DIR="/etc/roundcube"
RC_DRIVERS_DIR="/usr/share/roundcube/plugins/password/drivers"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

if [ "$(id -u)" != '0' ]; then
	echo "ERROR: h-add-sys-roundcube must be run as root"
	exit 10
fi

if [ -z "$HESTIA" ]; then HESTIA="/usr/local/hestia"; fi

if ! echo "$DB_SYSTEM" | grep -qw 'mysql'; then
	echo "ERROR: MySQL not available. Installation aborted."
	exit 2
fi

check_hestia_demo_mode

# Already installed?
if echo "$WEBMAIL_SYSTEM" | grep -qw 'roundcube' \
	&& [ -f "$RC_CONFIG_DIR/config.inc.php" ] \
	&& [ -f "$RC_CONFIG_DIR/debian-db.php" ]; then
	echo "INFO: Roundcube is already installed and configured."
	exit 0
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Prevent dbconfig-common from auto-configuring the database.
# debconf-set-selections writes to the debconf database before apt-get runs —
# the selection persists for the entire transaction including any deferred
# dpkg --configure calls, so no interactive DB prompt will appear.
echo "roundcube-core roundcube/dbconfig-install boolean false" \
	| debconf-set-selections

DEBIAN_FRONTEND=noninteractive apt-get -y install \
	roundcube roundcube-mysql roundcube-plugins

# Create dedicated MySQL database and user
dbpass=$(generate_password)
db_client="mysql"
[ -x /usr/bin/mariadb ] && db_client="mariadb"

# Guard against name collision: bail if a 'roundcube' database already exists
# from a source not managed by this HestiaRE instance. Without this check,
# CREATE DATABASE IF NOT EXISTS would silently succeed against a foreign DB,
# then write debian-db.php with a new password that doesn't match the
# existing user — leaving a broken but non-obvious configuration.
if $db_client -e "SHOW DATABASES LIKE 'roundcube'" 2>/dev/null | grep -q 'roundcube'; then
	echo "ERROR: Database 'roundcube' already exists but is not managed by this HestiaRE instance."
	echo "       Remove it manually first, or run h-remove-sys-roundcube if it was a previous install."
	exit 1
fi

$db_client -e "CREATE DATABASE IF NOT EXISTS \`roundcube\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci" \
	|| { echo "ERROR: Failed to create roundcube database"; exit 1; }
$db_client -e "CREATE USER IF NOT EXISTS 'roundcube'@'localhost' IDENTIFIED BY '$dbpass'" \
	|| { echo "ERROR: Failed to create roundcube database user"; exit 1; }
$db_client -e "GRANT ALL ON \`roundcube\`.* TO 'roundcube'@'localhost'" \
	|| { echo "ERROR: Failed to grant roundcube database privileges"; exit 1; }
$db_client -e "FLUSH PRIVILEGES"
$db_client roundcube < /usr/share/roundcube/SQL/mysql.initial.sql \
	|| { echo "ERROR: Failed to initialize roundcube database schema"; exit 1; }

# Write /etc/roundcube/debian-db.php (bypasses debconf DB configuration).
# roundcube-core reads this file via debian-db-roundcube.php to build the DSN.
cat > "$RC_CONFIG_DIR/debian-db.php" <<'PHP'
<?php
$dbtype='mysql';
$dbserver='localhost';
$dbport='';
$dbname='roundcube';
$dbuser='roundcube';
$dbpass='_RCPASS_';
$basepath='/var/lib/roundcube';
?>
PHP
sed -i "s/_RCPASS_/$dbpass/" "$RC_CONFIG_DIR/debian-db.php"
chmod 640 "$RC_CONFIG_DIR/debian-db.php"
chown root:caddy "$RC_CONFIG_DIR/debian-db.php"

# Generate encryption key and write main config
des_key="$(openssl rand -base64 30 | tr -d '/' | cut -c1-24)"
cat > "$RC_CONFIG_DIR/config.inc.php" <<'PHP'
<?php
// DB connection via Debian package mechanism (/etc/roundcube/debian-db.php)
include('/etc/roundcube/debian-db-roundcube.php');

$config['imap_host'] = 'localhost:143';
$config['smtp_host'] = 'localhost:587';
$config['des_key'] = '_DES_KEY_';
$config['max_recipients'] = 100;
$config['plugins'] = ['password', 'newmail_notifier', 'zipdownload', 'archive'];
$config['log_dir'] = '/var/log/roundcube/';
$config['smtp_log'] = false;
$config['log_session'] = true;
$config['imap_conn_options'] = ['ssl' => [
	'verify_peer' => false,
	'verify_peer_name' => false,
	'cafile' => '/etc/ssl/certs/ca-certificates.crt',
]];
$config['smtp_conn_options'] = ['ssl' => [
	'verify_peer' => false,
	'verify_peer_name' => false,
	'cafile' => '/etc/ssl/certs/ca-certificates.crt',
]];
PHP
sed -i "s/_DES_KEY_/$des_key/" "$RC_CONFIG_DIR/config.inc.php"
chmod 644 "$RC_CONFIG_DIR/config.inc.php"
chown root:caddy "$RC_CONFIG_DIR/config.inc.php"

# Deploy HestiaRE password driver.
# Extra files in apt-managed directories survive package upgrades —
# dpkg only removes files it originally installed.
cp -f "$HESTIA/share/roundcube/hestia.php" "$RC_DRIVERS_DIR/hestia.php"
chmod 644 "$RC_DRIVERS_DIR/hestia.php"

# Write password plugin config
# The OS package provides /etc/roundcube/plugins/password/ with a symlink from
# /usr/share/roundcube/plugins/password/config.inc.php — we just write our config.
cat > "$RC_CONFIG_DIR/plugins/password/config.inc.php" <<'PHP'
<?php
$config['password_driver'] = 'hestia';
$config['password_confirm_current'] = true;
$config['password_minimum_length'] = 8;
$config['password_log'] = false;
$config['password_hestia_host'] = 'localhost';
$config['password_hestia_port'] = '8083';
PHP
chmod 644 "$RC_CONFIG_DIR/plugins/password/config.inc.php"
chown root:caddy "$RC_CONFIG_DIR/plugins/password/config.inc.php"

# Deploy plugin configs for newmail_notifier and zipdownload
cp -f "$HESTIA/share/roundcube/plugins/config_newmail_notifier.inc.php" \
	"/usr/share/roundcube/plugins/newmail_notifier/config.inc.php"
cp -f "$HESTIA/share/roundcube/plugins/config_zipdownload.inc.php" \
	"/usr/share/roundcube/plugins/zipdownload/config.inc.php"

# Ensure log directory exists with correct ownership
mkdir -p /var/log/roundcube
chown caddy:caddy /var/log/roundcube
chmod 750 /var/log/roundcube
# Log rotation: the fail2ban roundcube-auth jail tails /var/log/roundcube/errors.log,
# so the log must rotate. This fragment was previously an orphan in the install
# tree (never deployed by anything) — wired up here (#234).
cp -f "$HESTIA/share/roundcube/logrotate" /etc/logrotate.d/roundcube

# Panel-Caddy delivery (#205): Roundcube renders in a dedicated caddy FPM pool
# behind Caddy's internal loopback listener (127.0.0.1:8090); the per-domain
# webmail.<domain> vhosts reverse-proxy to it. The temp dir must be writable by
# the pool user (Debian ships it www-data-owned); the logs symlink already points
# at /var/log/roundcube, chowned caddy:caddy above.
chown caddy:caddy /var/lib/roundcube/temp 2> /dev/null || true
cp -f "$HESTIA/share/panel-php/pool.d/roundcube.conf" /etc/php/hestia/fpm/pool.d/roundcube.conf
systemctl reload hestia-php 2> /dev/null || systemctl restart hestia-php 2> /dev/null || true
cp -f "$HESTIA/share/panel-caddy/webmail-roundcube.conf" /etc/caddy/webmail-roundcube.conf
# Panel-URL route (#205): :8083/webmail serves Roundcube for admin access without a
# customer domain (phpMyAdmin/Adminer model), sharing the pool above. Roundcube-only
# — SnappyMail is root-mounted and cannot run under a sub-path (see the template).
mkdir -p /etc/caddy/apps
cp -f "$HESTIA/share/panel-caddy/apps/webmail.tpl" /etc/caddy/apps/webmail.conf
systemctl try-restart caddy > /dev/null 2>&1 || true

# Update hestia.conf
if [ -z "$(grep WEBMAIL_SYSTEM "$HESTIA/conf/hestia.conf")" ]; then
	$BIN/h-change-sys-config-value 'WEBMAIL_SYSTEM' 'roundcube'
elif ! echo "$WEBMAIL_SYSTEM" | grep -qw 'roundcube'; then
	if [ -n "$WEBMAIL_SYSTEM" ]; then
		$BIN/h-change-sys-config-value 'WEBMAIL_SYSTEM' "roundcube,$WEBMAIL_SYSTEM"
	else
		$BIN/h-change-sys-config-value 'WEBMAIL_SYSTEM' 'roundcube'
	fi
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

set_install_component MAIL_WEBMAILER ROUNDCUBE

$BIN/h-log-action "system" "Info" "Plugins" "Roundcube installed (OS package)."
log_event "$OK" "$ARGUMENTS"
