#!/bin/bash
# info: install ClamAV mail antivirus
# options: NONE
#
# example: h-add-sys-clamav
#
# Installs ClamAV (clamav-daemon + clamav-freshclam) and wires it as the mail
# antivirus: hardened clamd.conf, Debian-exim joins the clamav group for socket
# access, and the exim CLAMD macro + ANTIVIRUS_SYSTEM=clamav are armed ONLY once
# clamd actually answers on the socket. If the virus DB is still downloading
# (clamd can't start without a DB), the macro stays OFF and a WARN tells the admin
# to re-run once the DB is ready — so ClamAV is never "armed but blind":
# av_scanner=clamd: + malware=*/defer_ok is FAIL-OPEN, so a dead clamd would
# silently accept mail unscanned. Idempotent — a re-run arms the macro as soon as
# clamd is up. Mirrors h-add-sys-rspamd. Also called by the installer.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
# live component state
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"

EXIM_USER="Debian-exim"
CLAMD_USER="clamav"
CLAMD_DB_DIR="/var/lib/clamav"
EXIM_TPL="/etc/exim4/exim4.conf.template"

# clamd answers on its socket? (the only proof it can actually scan)
clamd_alive() { clamdscan --ping 1 > /dev/null 2>&1; }

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

if [ "x$(id -u)" != 'x0' ]; then
	echo "Error: Script can be run executed only by root"
	exit 10
fi

is_system_enabled "$MAIL_SYSTEM" 'MAIL_SYSTEM'

check_hestia_demo_mode

# already fully active? idempotent early-exit
if grep -q '^CLAMD = yes' "$EXIM_TPL" 2> /dev/null \
	&& [ "$ANTIVIRUS_SYSTEM" = 'clamav' ] && clamd_alive; then
	echo "INFO: ClamAV is already installed and active."
	exit 0
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Install if absent (clamav = the clamdscan client, used for the socket ping; the
# daemon package alone only recommends it). Idempotent so a re-run just proceeds.
if ! dpkg -l clamav-daemon 2> /dev/null | grep -q '^ii'; then
	echo "Installing ClamAV (clamav clamav-daemon clamav-freshclam)..."
	apt-get -y -qq install clamav clamav-daemon clamav-freshclam > /dev/null 2>&1
	if ! dpkg -l clamav-daemon 2> /dev/null | grep -q '^ii'; then
		echo "ERROR: ClamAV installation failed."
		exit "$E_INVALID"
	fi
fi

# hardened config + BIDIRECTIONAL group access (both idempotent):
#  - exim joins clamav  → write to the clamd socket
#  - clamav joins exim  → READ the exim spool (/var/spool/exim4/scan, 0750 exim:exim)
# The second is load-bearing: without it clamd hits "Permission denied" on the spool,
# ClamAV returns ERROR, and malware=*/defer_ok (fail-open) delivers mail UNSCANNED.
cp -f "$HESTIA/share/clamav/clamd.conf" /etc/clamav/clamd.conf
usermod -aG "$CLAMD_USER" "$EXIM_USER"
usermod -aG "$EXIM_USER" "$CLAMD_USER"

# A DB preserved by h-delete-sys-clamav may carry a stale uid/gid if the purge+reinstall
# re-allocated the clamav system user — reclaim it so freshclam/clamd can read+update it.
[ -d "$CLAMD_DB_DIR" ] && chown -R "$CLAMD_USER:$CLAMD_USER" "$CLAMD_DB_DIR"

# socket 0660: clamd is socket-activated, so the .socket unit (default 0666) — not
# clamd.conf's LocalSocketMode — owns the live mode. A drop-in enforces 0660; the
# restart recreates /run/clamav/clamd.ctl with it (see share/clamav/socket-hardening.conf).
mkdir -p /etc/systemd/system/clamav-daemon.socket.d
cp -f "$HESTIA/share/clamav/socket-hardening.conf" \
	/etc/systemd/system/clamav-daemon.socket.d/hardening.conf
systemctl daemon-reload
systemctl restart clamav-daemon.socket > /dev/null 2>&1

# AppArmor: guarantee clamd can read the exim spool it scans. The stock profile
# already allows it, but a stricter base-install profile might not — and then clamd
# errors and defer_ok fails OPEN (mail unscanned). Local override, mirror of proftpd;
# a no-op where no clamd profile ships.
if [ -f /etc/apparmor.d/usr.sbin.clamd ]; then
	mkdir -p /etc/apparmor.d/local
	cp -f "$HESTIA/share/clamav/apparmor-local" /etc/apparmor.d/local/usr.sbin.clamd
	apparmor_parser -r /etc/apparmor.d/usr.sbin.clamd > /dev/null 2>&1 || true
fi

# Virus DB: let the clamav-freshclam SERVICE pull it. Do NOT run freshclam by hand
# — the service (started by apt) holds the lock; a manual run dies with "freshclam
# is already running". Bounded-wait on the DB files while the service downloads.
systemctl enable --now clamav-freshclam > /dev/null 2>&1
echo "Waiting for the virus database (freshclam, up to 5 min)..."
db_ready=0
for _ in $(seq 1 300); do
	if { [ -e "$CLAMD_DB_DIR/main.cvd" ] || [ -e "$CLAMD_DB_DIR/main.cld" ]; } \
		&& { [ -e "$CLAMD_DB_DIR/daily.cvd" ] || [ -e "$CLAMD_DB_DIR/daily.cld" ]; }; then
		db_ready=1
		break
	fi
	sleep 1
done

# clamd only starts once the DB exists; then it needs a bit to load it into RAM.
# restart (not just enable --now): apt's postinst may already have forked clamd
# BEFORE the usermod above, so a plain start wouldn't refresh its groups — restart
# guarantees a fresh fork carrying the Debian-exim group + the 0660 socket.
systemctl enable clamav-daemon > /dev/null 2>&1
systemctl restart clamav-daemon > /dev/null 2>&1
clamd_up=0
if [ "$db_ready" = 1 ]; then
	for _ in $(seq 1 60); do
		clamd_alive && { clamd_up=1; break; }
		sleep 1
	done
fi

# Arm ONLY when clamd answers — otherwise leave the macro off and stay honest.
if [ "$clamd_up" = 1 ]; then
	sed -i 's/^#CLAMD = yes/CLAMD = yes/' "$EXIM_TPL"
	systemctl restart exim4
	if ! systemctl is-active --quiet exim4; then
		echo "ERROR: exim4 failed to restart with ClamAV enabled."
		exit "$E_RESTART"
	fi
	$BIN/h-change-sys-config-value 'ANTIVIRUS_SYSTEM' 'clamav'
	echo "ClamAV is now active (mail antivirus)."
else
	# installed but not scanning yet: macro OFF, ANTIVIRUS_SYSTEM untouched, so no
	# unscanned-but-flagged mail slips through the fail-open scanner.
	echo "WARNING: ClamAV installed, but clamd is not answering yet (virus DB still"
	echo "         downloading). Antivirus is NOT active. Re-run 'h-add-sys-clamav'"
	echo "         once the DB is ready to activate scanning."
fi

set_install_component ADDON_CLAMAV true

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

$BIN/h-log-action "system" "Info" "System" "Installed ClamAV mail antivirus."
log_event "$OK" "$ARGUMENTS"

exit
