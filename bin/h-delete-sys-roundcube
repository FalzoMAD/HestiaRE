#!/bin/bash
# info: Remove Roundcube webmail client
# options: NONE
#
# This function removes Roundcube packages, drops the dedicated database
# and user, removes configuration, and clears the panel integration.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
# live component state (COMPONENT_MAIL_WEBMAILER), if present
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"

RC_CONFIG_DIR="/etc/roundcube"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

if [ "$(id -u)" != '0' ]; then
	echo "ERROR: h-delete-sys-roundcube must be run as root"
	exit 10
fi

if [ -z "$HESTIA" ]; then HESTIA="/usr/local/hestia"; fi

check_hestia_demo_mode

if ! echo "$WEBMAIL_SYSTEM" | grep -qw 'roundcube'; then
	echo "ERROR: Roundcube is not installed."
	exit 1
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Remove packages
DEBIAN_FRONTEND=noninteractive apt-get -y purge \
	roundcube roundcube-core roundcube-mysql roundcube-plugins
DEBIAN_FRONTEND=noninteractive apt-get -y autoremove

# INTENTIONAL DATA LOSS: the roundcube DB (UI prefs + contacts, NOT mail — that
# lives in Dovecot) is dropped; no migration across a delete/re-add cycle.
db_client="mysql"
[ -x /usr/bin/mariadb ] && db_client="mariadb"

$db_client -e "DROP DATABASE IF EXISTS \`roundcube\`"
$db_client -e "DROP USER IF EXISTS 'roundcube'@'localhost'"
$db_client -e "FLUSH PRIVILEGES"

# Remove credentials file (contains DB password)
rm -f "$RC_CONFIG_DIR/debian-db.php"

# Remove HestiaRE password driver if it was deployed by us
rm -f "/usr/share/roundcube/plugins/password/drivers/hestia.php"

# Remove remaining config directory if it exists
rm -rf "$RC_CONFIG_DIR"

# Remove the logrotate fragment deployed by h-add-sys-roundcube
rm -f /etc/logrotate.d/roundcube

# Panel-Caddy teardown: listener + panel route + FPM pool
rm -f /etc/caddy/webmail-roundcube.conf
rm -f /etc/caddy/apps/webmail.conf
systemctl try-restart caddy > /dev/null 2>&1 || true
rm -f /etc/php/hestia/fpm/pool.d/roundcube.conf
systemctl reload hestia-php 2> /dev/null || systemctl restart hestia-php 2> /dev/null || true

# Update hestia.conf — remove roundcube from WEBMAIL_SYSTEM
new_webmail=$(echo "$WEBMAIL_SYSTEM" | sed 's/roundcube,\?//g; s/,$//')
if [ -z "$new_webmail" ]; then
	$BIN/h-change-sys-config-value 'WEBMAIL_SYSTEM' ''
else
	$BIN/h-change-sys-config-value 'WEBMAIL_SYSTEM' "$new_webmail"
fi

# re-render mail domains so vhosts stop proxying to the removed listener
# (fall back to the remaining client, or the safe 'disabled' vhost)
$BIN/h-update-mail-templates yes > /dev/null 2>&1 || true

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# reset the wizard selection only if Roundcube was the recorded one (don't clobber a secondary)
if [ "${COMPONENT_MAIL_WEBMAILER:-}" = "ROUNDCUBE" ]; then
	set_install_component MAIL_WEBMAILER NONE
fi

$BIN/h-log-action "system" "Info" "Plugins" "Roundcube removed."
log_event "$OK" "$ARGUMENTS"
