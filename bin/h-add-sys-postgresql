#!/bin/bash
# info: install PostgreSQL database server
# options: NONE
#
# example: h-add-sys-postgresql
#
# Installs PostgreSQL and registers it as a local database host so the panel can
# create and manage PostgreSQL databases + users (#121, full integration — the
# lifecycle helpers in func/db.sh and the web UI were already present; only the
# host registration was missing, which is why PostgreSQL was CLI-only before).
#
# The panel connects as the `postgres` superuser over TCP loopback (parity with
# the MariaDB root credential): a password is set on it (its socket peer-auth is
# unaffected), and Debian/Ubuntu's default pg_hba already allows scram-sha-256 on
# 127.0.0.1, so no pg_hba edit is needed. The `postgres` role is used rather than a
# dedicated one because func/db.sh connects without an explicit -d, i.e. to the
# role-named database — which only `postgres` has. The credential lives in the host
# registry (conf/pgsql.conf, 0660 root), never in install.conf.
#
# Idempotency is artefact-based (package + host registration), NOT the wizard
# COMPONENT_DB_POSTGRESQL flag (that is the selection, not the install state, #121).
# Readiness is checked with pg_isready, NOT `systemctl is-active postgresql` — the
# latter is a oneshot umbrella unit that reports active even when the cluster is
# down (#121 K2).
#
# New h-* command — no v-* symlink.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"

MGMT_ROLE="postgres"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

if [ "x$(id -u)" != 'x0' ]; then
	echo "Error: Script can be run executed only by root"
	exit 10
fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

# Idempotency guard (artefact-based). Package + registered host = fully installed.
if dpkg -l postgresql 2> /dev/null | grep -q '^ii' \
	&& grep -qs "HOST='localhost'" "$HESTIA/conf/pgsql.conf"; then
	echo "INFO: PostgreSQL is already installed."
	exit 0
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

echo "[ * ] Installing PostgreSQL packages..."
apt-get -qq update
# postgresql-common first, in its own transaction: the postgresql metapackage's
# debconf .config runs pg_lsclusters during pre-configuration, before
# postgresql-common is unpacked when both are in one transaction (#353).
DEBIAN_FRONTEND=noninteractive apt-get -y -qq install postgresql-common > /dev/null 2>&1 || true
DEBIAN_FRONTEND=noninteractive apt-get -y -qq install postgresql postgresql-contrib > /dev/null 2>&1
if ! dpkg -l postgresql 2> /dev/null | grep -q '^ii'; then
	echo "ERROR: PostgreSQL package install failed"
	exit "$E_INVALID"
fi

# Ensure the versioned cluster is up, then verify with pg_isready (K2).
PG_MAJOR=$(pg_lsclusters -h 2> /dev/null | awk 'NR==1{print $1}')
systemctl enable postgresql > /dev/null 2>&1 || true
systemctl start "postgresql@${PG_MAJOR}-main" > /dev/null 2>&1 \
	|| systemctl start postgresql > /dev/null 2>&1 || true
_ready=0
for _ in $(seq 1 15); do
	pg_isready -q 2> /dev/null && { _ready=1; break; }
	sleep 1
done
if [ "$_ready" != 1 ]; then
	echo "ERROR: PostgreSQL cluster is not ready (pg_isready)"
	exit "$E_RESTART"
fi

echo "[ * ] Setting management credentials..."
# Set a password on the postgres superuser for loopback TCP login by the panel.
# Socket peer-auth (sudo -u postgres psql) is unaffected — peer ignores passwords.
PGPASS=$(tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 16 || true)
sudo -u postgres psql -qc "ALTER ROLE postgres WITH PASSWORD '$PGPASS';" > /dev/null 2>&1

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

set_install_component DB_POSTGRESQL true

# Register the local host — composes DB_SYSTEM+=pgsql (the h-add-database-host
# guard fix from #121 makes the first pgsql host registrable; is_pgsql_host_alive
# verifies the TCP + password login works). This is what lets the panel offer and
# manage PostgreSQL databases.
if ! "$BIN/h-add-database-host" pgsql localhost "$MGMT_ROLE" "$PGPASS" > /dev/null 2>&1; then
	echo "[ ! ] PostgreSQL host registration reported an issue"
fi

echo "[ OK ] PostgreSQL installed"

$BIN/h-log-action "system" "Info" "System" "PostgreSQL installed."
log_event "$OK" "$ARGUMENTS"

exit
