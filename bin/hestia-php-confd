#!/bin/bash
# info: rebuild the panel PHP's isolated conf.d (FPM + CLI)
# options: [VERSION]
#
# example: hestia-php-confd 8.3
#
# The panel PHP runs with PHP_INI_SCAN_DIR pointing at its own conf.d (set by
# the hestia-php-fpm and hestia-php wrappers) so it loads a fixed, curated
# extension set instead of whatever customers have enabled/disabled on the same
# PHP version's conf.d. This helper (re)builds both directories —
# /etc/php/hestia/fpm/conf.d and /etc/php/hestia/cli/conf.d — from the
# version's mods-available, keeping the Debian priority prefixes. Run after the
# panel install and by h-change-sys-panel-php (the mods-available path is
# version-specific, so it must follow the pinned version).
#
# Not a user-facing command — no v-* symlink.

version="${1:-$(cat /etc/php/hestia/php-version 2> /dev/null)}"

if [ -z "$version" ]; then
	echo "ERROR: no panel PHP version (arg or /etc/php/hestia/php-version)."
	exit 1
fi

mods="/etc/php/$version/mods-available"

if [ ! -d "$mods" ]; then
	echo "ERROR: $mods not found — is PHP $version installed?"
	exit 1
fi

# Extension sets per target, split by how badly the consumer breaks without
# them: a missing critical extension is a hard failure so a degraded panel is
# caught here at build time instead of surfacing as a runtime fatal later; a
# missing optional one only warns.
#
# FPM (the panel web UI, verified against the panel code):
#   critical — the panel is non-functional without these:
#       mysqlnd pdo mysqli pdo_mysql  DB access chain
#       mbstring                      string handling throughout the UI
#       gettext                       i18n — the panel's _() translation calls
#   optional — used but not fatal on every render:
#       opcache          performance (Zend)
#       curl gmp zip     panel-stage set
#       ftp              FTP account management
#
# CLI (bin/hestia-php, verified against its consumers): the in-tree callers —
# func/main.sh validators (filter_var, kv-parser), the 2FA TOTP/QR helpers,
# h-add-web-domain-redirect (parse_url) — need only compiled-in PHP. The
# curated set exists for composer, which h-add-sys-filemanager runs through
# hestia-php: phar (composer IS a phar; openssl for its downloads is
# compiled-in on Debian/Sury), mbstring/iconv/ctype (real extensions instead
# of composer's bundled polyfills), plus curl/zip to speed up downloads and
# archive extraction. No DB chain, no gettext — no CLI consumer uses them.
#
# Deliberately excluded from the panel set: imagick, imap, ldap, soap, bcmath,
# apcu, pspell, … (customer-app extensions). intl/exif moved into the webmail
# set below once the panel FPM started serving Roundcube/SnappyMail (#205).
fpm_critical="mysqlnd pdo mysqli pdo_mysql mbstring gettext"
fpm_optional="opcache curl gmp zip ftp"
# App tools served by the SAME hestia FPM master (phpMyAdmin, Adminer): their
# pools live under this master and share this conf.d, so the tools' extensions
# must be curated here too. Without them the bundled DB web UIs die with runtime
# fatals (e.g. phpMyAdmin: "undefined function ctype_alpha()") instead of the
# clean build-time error this script exists to give.
#   critical — always present via php-common (ctype/iconv/fileinfo) and php-xml
#              (simplexml/xmlwriter/xmlreader); phpMyAdmin hard-needs them.
#   optional — installed for the panel version in the panel stage: gd/bz2 for
#              phpMyAdmin, pgsql/pdo_pgsql for Adminer->PostgreSQL.
# (sodium is compiled-in on Debian/Sury — no mods-available .ini — so it needs
#  no symlink and is deliberately not listed.)
fpm_apps_critical="ctype iconv fileinfo simplexml xmlwriter xmlreader"
fpm_apps_optional="gd bz2 pgsql pdo_pgsql"
# Webmail (Roundcube/SnappyMail) is served by the SAME hestia FPM master via the
# internal loopback listeners on :8090/:8091 (#205), so its pools share this
# conf.d and its extensions must be curated here too — same self-contained model
# as the phpMyAdmin/Adminer set above.
#   critical — intl: IDN handling (rcube_utils::idn_to_ascii ->
#              INTL_IDNA_VARIANT_UTS46). Roundcube fatals on the very first login
#              without it; SnappyMail needs it for internationalised addresses.
#            phar: SnappyMail's change-password plugin scans its driver .phar
#              files at bootstrap ("Class Phar not found" -> blank page). Ships
#              with php-common (phar.ini in mods-available), so no apt line — it
#              only needs the symlink the FPM set was missing.
#   optional — exif: Roundcube image orientation for attachment previews.
# php${VER}-intl is installed unconditionally in the panel stage (like pgsql for
# Adminer), so webmail add/remove never has to touch the panel PHP config.
fpm_webmail_critical="intl phar"
fpm_webmail_optional="exif"
cli_critical="mbstring ctype iconv phar"
cli_optional="curl zip"

missing_critical=""

build_confd() {
	local dst="$1" critical="$2" optional="$3"
	local e src prio

	mkdir -p "$dst"
	find "$dst" -maxdepth 1 -name '*.ini' -delete 2> /dev/null

	for e in $critical $optional; do
		src="$mods/$e.ini"
		if [ ! -f "$src" ]; then
			case " $critical " in
				*" $e "*)
					echo "ERROR: critical extension '$e' missing ($src)."
					missing_critical="$missing_critical $e"
					;;
				*) echo "WARN: $src missing — skipped." ;;
			esac
			continue
		fi
		# Keep the Debian load-order prefix (e.g. 10-opcache, 20-curl); default 20.
		prio=$(sed -n 's/^; *priority=\([0-9]\{1,\}\).*/\1/p' "$src" | head -n1)
		ln -sf "$src" "$dst/${prio:-20}-$e.ini"
	done
}

build_confd /etc/php/hestia/fpm/conf.d "$fpm_critical $fpm_apps_critical $fpm_webmail_critical" "$fpm_optional $fpm_apps_optional $fpm_webmail_optional"
build_confd /etc/php/hestia/cli/conf.d "$cli_critical" "$cli_optional"

if [ -n "$missing_critical" ]; then
	echo "ERROR: panel PHP conf.d incomplete — missing critical extension(s):$missing_critical" >&2
	exit 1
fi

exit 0
