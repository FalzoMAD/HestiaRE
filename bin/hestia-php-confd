#!/bin/bash
# info: rebuild the panel PHP's isolated conf.d (FPM + CLI)
# options: [VERSION]
#
# example: hestia-php-confd 8.3
#
# The panel PHP (hestia-php-fpm/hestia-php wrappers, PHP_INI_SCAN_DIR) loads a
# curated extension set from its own conf.d, independent of what customers toggle
# on the same version. This (re)builds /etc/php/hestia/{fpm,cli}/conf.d from the
# version's mods-available, keeping Debian priority prefixes. Run after panel
# install and by h-change-sys-panel-php (version-specific path).
#
# EVERY app on the single hestia FPM master shares this fpm conf.d — panel UI,
# phpMyAdmin/Adminer, and the webmail clients (Roundcube/SnappyMail). Before
# dropping any extension, check all three groups (fpm_*, fpm_apps_*,
# fpm_webmail_*): a 2026-07 audit removed `dom` after checking only panel + DB
# tools and 500'd every Roundcube page. Critical = hard build-time failure;
# optional = warn. See CODEMAP panel_php_service.confd_isolation for the coupling.

version="${1:-$(cat /etc/php/hestia/php-version 2> /dev/null)}"

if [ -z "$version" ]; then
	echo "ERROR: no panel PHP version (arg or /etc/php/hestia/php-version)."
	exit 1
fi

mods="/etc/php/$version/mods-available"

if [ ! -d "$mods" ]; then
	echo "ERROR: $mods not found — is PHP $version installed?"
	exit 1
fi

# panel UI: DB chain + mbstring + gettext(i18n) critical; perf/stage extras optional
fpm_critical="mysqlnd pdo mysqli pdo_mysql mbstring gettext"
fpm_optional="opcache curl gmp zip ftp"
# phpMyAdmin/Adminer: ctype/iconv/fileinfo (php-common) + xml family (php-xml) critical
fpm_apps_critical="ctype iconv fileinfo simplexml xmlwriter xmlreader"
fpm_apps_optional="gd bz2 pgsql pdo_pgsql"
# webmail: intl(IDN), phar(SnappyMail plugins), dom(Roundcube renders every page) critical
fpm_webmail_critical="intl phar dom"
fpm_webmail_optional="exif"
# CLI (bin/hestia-php): only composer needs these; no DB chain, no gettext
cli_critical="mbstring ctype iconv phar"
cli_optional="curl zip"

missing_critical=""

build_confd() {
	local dst="$1" critical="$2" optional="$3"
	local e src prio

	mkdir -p "$dst"
	find "$dst" -maxdepth 1 -name '*.ini' -delete 2> /dev/null

	for e in $critical $optional; do
		src="$mods/$e.ini"
		if [ ! -f "$src" ]; then
			case " $critical " in
				*" $e "*)
					echo "ERROR: critical extension '$e' missing ($src)."
					missing_critical="$missing_critical $e"
					;;
				*) echo "WARN: $src missing — skipped." ;;
			esac
			continue
		fi
		# keep the Debian load-order prefix (10-opcache, 20-curl); default 20
		prio=$(sed -n 's/^; *priority=\([0-9]\{1,\}\).*/\1/p' "$src" | head -n1)
		ln -sf "$src" "$dst/${prio:-20}-$e.ini"
	done
}

build_confd /etc/php/hestia/fpm/conf.d "$fpm_critical $fpm_apps_critical $fpm_webmail_critical" "$fpm_optional $fpm_apps_optional $fpm_webmail_optional"
build_confd /etc/php/hestia/cli/conf.d "$cli_critical" "$cli_optional"

if [ -n "$missing_critical" ]; then
	echo "ERROR: panel PHP conf.d incomplete — missing critical extension(s):$missing_critical" >&2
	exit 1
fi

exit 0
