#!/bin/bash
# info: rebuild the panel FPM's isolated PHP conf.d
# options: [VERSION]
#
# example: hestia-php-confd 8.3
#
# The panel FPM runs with PHP_INI_SCAN_DIR=/etc/php/hestia/fpm/conf.d (set by the
# hestia-php-fpm wrapper) so it loads a fixed, curated extension set instead of
# whatever customers have enabled/disabled on the same PHP version's conf.d. This
# helper (re)builds that directory from the version's mods-available, keeping the
# Debian priority prefixes. Run after the panel install and by h-change-sys-panel-php
# (the mods-available path is version-specific, so it must follow the pinned version).
#
# Not a user-facing command — no v-* symlink.

version="${1:-$(cat /etc/php/hestia/php-version 2> /dev/null)}"

if [ -z "$version" ]; then
	echo "ERROR: no panel PHP version (arg or /etc/php/hestia/php-version)."
	exit 1
fi

mods="/etc/php/$version/mods-available"
dst="/etc/php/hestia/fpm/conf.d"

if [ ! -d "$mods" ]; then
	echo "ERROR: $mods not found — is PHP $version installed?"
	exit 1
fi

# Extensions the panel actually needs (verified against the panel code), split by
# how badly the panel breaks without them:
#   critical — the panel is non-functional without these; a missing one is a hard
#     failure so a degraded panel is caught here at build time instead of
#     surfacing as a runtime fatal on a random page later:
#       mysqlnd pdo mysqli pdo_mysql  DB access chain
#       mbstring                      string handling throughout the UI
#       gettext                       i18n — the panel's _() translation calls
#   optional — used but not fatal on every render; a missing one only warns:
#       opcache          performance (Zend)
#       curl gmp zip     panel-stage set
#       ftp              FTP account management
#       dom              DOMDocument (from php-xml)
# Deliberately excluded: imagick, imap, ldap, pgsql, gd, soap, intl, bcmath,
# apcu, exif, pspell, … (customer-app extensions, not used by the panel).
critical="mysqlnd pdo mysqli pdo_mysql mbstring gettext"
optional="opcache curl gmp zip ftp dom"

mkdir -p "$dst"
find "$dst" -maxdepth 1 -name '*.ini' -delete 2> /dev/null

missing_critical=""
for e in $critical $optional; do
	src="$mods/$e.ini"
	if [ ! -f "$src" ]; then
		case " $critical " in
			*" $e "*)
				echo "ERROR: critical extension '$e' missing ($src)."
				missing_critical="$missing_critical $e"
				;;
			*) echo "WARN: $src missing — skipped." ;;
		esac
		continue
	fi
	# Keep the Debian load-order prefix (e.g. 10-opcache, 20-curl); default 20.
	prio=$(sed -n 's/^; *priority=\([0-9]\{1,\}\).*/\1/p' "$src" | head -n1)
	ln -sf "$src" "$dst/${prio:-20}-$e.ini"
done

if [ -n "$missing_critical" ]; then
	echo "ERROR: panel PHP conf.d incomplete — missing critical extension(s):$missing_critical" >&2
	exit 1
fi

exit 0
