#!/bin/bash
# info: change rspamd controller (web UI) password
# options: [PASSWORD]
#
# example: h-change-sys-rspamd-password
#
# Sets the password for the rspamd controller — the web UI at /rspamd/ on
# the panel port and the learn/scan/stat API on 127.0.0.1:11334. Only the
# hash (rspamadm pw) is stored in /etc/rspamd/local.d/worker-controller.inc;
# the plaintext is printed once, so capture it. Without an argument a random
# password is generated. New h-* command — no v-* symlink.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
password=$1
HIDE=1

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

conf="/etc/rspamd/local.d/worker-controller.inc"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

if [ "$ANTISPAM_SYSTEM" != "rspamd" ]; then
	check_result "$E_NOTEXIST" "rspamd is not the active antispam system"
fi
if ! command -v rspamadm > /dev/null 2>&1; then
	check_result "$E_NOTEXIST" "rspamadm not found — is rspamd installed?"
fi
check_hestia_demo_mode

# Non-interactive (stdin not opened)
[[ -z "$password" && ! -t 0 ]] && read -r password

if [ -z "$password" ]; then
	password=$(generate_password)
fi
is_password_valid

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

hash=$(rspamadm pw --password "$password")
if [ -z "$hash" ]; then
	check_result "$E_UPDATE" "rspamadm pw failed to hash the password"
fi

# Replace via delete+append: the catena hash contains $ and other
# characters that are unsafe in a sed replacement string
sed -i '/^enable_password/d' "$conf"
printf 'enable_password = "%s";\n' "$hash" >> "$conf"

systemctl restart rspamd

echo "$password"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/h-log-action "system" "Warning" "Security" "rspamd controller password changed."
log_event "$OK" "$ARGUMENTS"

exit
