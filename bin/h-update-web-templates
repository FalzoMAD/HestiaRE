#!/bin/bash
# info: update web templates
# options: [RESTART] [SKIP]
#
# example: h-update-web-templates
#
# This function for obtaining updated web (Nginx/Apache2/PHP) templates from the Hestia package.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
restart=$1
skip=$2

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

is_format_valid 'restart'

# Detect whether the awstats template already has the geoip LoadPlugin enabled
awstats_patch=$(cat $HESTIA/templates/web/awstats/awstats.tpl | grep "LoadPlugin=\"geoip GEOIP_STANDARD /usr/share/GeoIP/GeoIP.dat\"")

# Web templates ship at $HESTIA/templates/web (delivered by the tarball) — there
# is no separate install source to copy from. Only the per-PHP-version FPM pool
# templates are generated here for the versions currently installed.
versions_list=$(ls -d /etc/php/*)
for php_ver in $versions_list; do
	version=$(echo $php_ver | sed 's/.*\///')
	[ ! -d "/etc/php/$version/fpm/pool.d/" ] && continue
	cp -f $HESTIA/share/php-fpm/multiphp.tpl ${WEBTPL}/php-fpm/PHP-${version/\./_}.tpl
done

if [ -n "$awstats_patch" ]; then
	# restore LoadPlugin variable
	echo "LoadPlugin=\"geoip GEOIP_STANDARD /usr/share/GeoIP/GeoIP.dat\"" >> $HESTIA/templates/web/awstats/awstats.tpl
fi

# Rebuilding web domains
if [ -z "$skip" ]; then
	for user in $("$BIN/h-list-users" list); do
		$BIN/h-rebuild-web-domains "$user" "no"
	done
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Restarting web server
$BIN/h-restart-web "$restart"
check_result $? "restart" > /dev/null 2>&1

$BIN/h-restart-proxy "$restart"
check_result $? "restart" > /dev/null 2>&1

$BIN/h-log-action "system" "Info" "Updates" "Default web domain templates updated."

exit
