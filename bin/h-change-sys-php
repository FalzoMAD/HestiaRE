#!/bin/bash
# info: Change default php version server wide
# options: VERSION

# example: h-change-sys-php 8.0

version=$1

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

check_args '1' "$#" 'VERSION'

# Verify php version format
if [[ ! $version =~ ^[0-9]+\.[0-9]+ ]]; then
	echo "The specified PHP version format is invalid, it should look like [0-9].[0-9]."
	echo "Example: 7.0, 7.4, 8.0"
	exit "$E_INVALID"
fi

# Check if php version exists
version_check=$($BIN/h-list-sys-php plain | grep "$version")
if [ -z "$version_check" ]; then
	echo "ERROR: Specified PHP version is not installed."
	exit "$E_INVALID"
fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# The default web PHP version is tracked solely by update-alternatives
# (set at the end of this script and read by multiphp_default_version). There
# is no shared www pool to re-home anymore — every domain has its own per-domain
# pool, so switching the default only needs a rebuild + backend restart (#397).
for user in $("$BIN/h-list-users" list); do
	$BIN/h-rebuild-web-domains "$user" 'no' > /dev/null 2>&1
	$BIN/h-rebuild-mail-domains "$user" 'no' > /dev/null 2>&1
done

# Reload "current" php version before reload everthing
$BIN/h-restart-web-backend '' $(multiphp_default_version)
$BIN/h-restart-web-backend
$BIN/h-restart-web
$BIN/h-restart-proxy

update-alternatives --set php /usr/bin/php$version

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

log_event "$OK" "$ARGUMENTS"
