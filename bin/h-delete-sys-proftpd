#!/bin/bash
# info: remove ProFTPD FTP server
# options: [FORCE]
#
# example: h-delete-sys-proftpd
#
# Purges proftpd-basic, removes the HestiaRE drop-ins, clears FTP_SYSTEM and the
# FTP firewall rule. Counterpart to h-add-sys-proftpd (#123).
# New h-* command — no v-* symlink.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

FORCE=$1

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
# live component state
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Checking root permissions
if [ "x$(id -u)" != 'x0' ]; then
	echo "ERROR: h-delete-sys-proftpd can only be executed by the root user"
	exit 10
fi

if [ -z "$HESTIA" ]; then HESTIA="/usr/local/hestia"; fi

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

# Not-installed guard is artefact-based, NOT flag-based: existing installs got
# proftpd from the old inline install_addons path and never had
# COMPONENT_ADDON_PROFTPD set, so a flag guard would wrongly refuse to remove it
# (the same twin-class trap that bit webmail). Guard on the package instead.
if ! dpkg -l proftpd-basic 2> /dev/null | grep -q '^ii' && [ "$FORCE" != 'yes' ]; then
	echo "ERROR: ProFTPD is not installed. Use FORCE=yes to clean up anyway."
	exit "$E_NOTEXIST"
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

systemctl disable --now proftpd > /dev/null 2>&1 || true
apt-get -y -qq purge proftpd-basic > /dev/null 2>&1
apt-get -y -qq autoremove > /dev/null 2>&1

# Remove our own drop-in (not owned by the package, so purge leaves it behind).
rm -f /etc/proftpd/conf.d/external_ip.conf

# Clear the FTP backend only if it is actually proftpd — never clobber another
# backend's value (symmetric to the add side's refusal to switch).
if [ "$FTP_SYSTEM" = 'proftpd' ]; then
	$BIN/h-change-sys-config-value 'FTP_SYSTEM' ''
fi

# Firewall: drop the FTP rule by locating its id via COMMENT='FTP'.
if is_system_enabled "$FIREWALL_SYSTEM" 'FIREWALL_SYSTEM' > /dev/null 2>&1 \
	&& [ -f "$CONF_DIR/firewall/rules.conf" ]; then
	ftp_rule=$(grep "COMMENT='FTP'" "$CONF_DIR/firewall/rules.conf" \
		| sed -n "s/.*RULE='\([0-9]*\)'.*/\1/p" | head -n1)
	if [ -n "$ftp_rule" ]; then
		$BIN/h-delete-firewall-rule "$ftp_rule" > /dev/null 2>&1 || true
	fi
fi

set_install_component ADDON_PROFTPD false

echo "ProFTPD has been removed."

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

$BIN/h-log-action "system" "Info" "System" "Removed ProFTPD FTP server."
log_event "$OK" "$ARGUMENTS"

exit
