#!/bin/bash
# info: remove ProFTPD FTP server
# options: [FORCE]
#
# example: h-delete-sys-proftpd
#
# Counterpart to h-add-sys-proftpd: purges all proftpd* packages, removes our
# drop-ins, clears FTP_SYSTEM and the FTP firewall rule.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

FORCE=$1

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"  # COMPONENT_* state

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

if [ "x$(id -u)" != 'x0' ]; then
	echo "ERROR: h-delete-sys-proftpd can only be executed by the root user"
	exit 10
fi

if [ -z "$HESTIA" ]; then HESTIA="/usr/local/hestia"; fi

check_hestia_demo_mode

# guard on the package, not COMPONENT_* — old inline installs never set the flag
if ! dpkg -l proftpd-core 2> /dev/null | grep -q '^ii' && [ "$FORCE" != 'yes' ]; then
	echo "ERROR: ProFTPD is not installed. Use FORCE=yes to clean up anyway."
	exit "$E_NOTEXIST"
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

systemctl disable --now proftpd > /dev/null 2>&1 || true
# purge every installed proftpd* package (glob — OS-agnostic, no error on absent names)
proftpd_installed="$(dpkg-query -W -f='${Package} ${db:Status-Status}\n' 'proftpd*' 2> /dev/null \
	| awk '$2 == "installed" {print $1}')"
if [ -n "$proftpd_installed" ]; then
	# shellcheck disable=SC2086
	apt-get -y -qq purge $proftpd_installed > /dev/null 2>&1
fi
apt-get -y -qq autoremove > /dev/null 2>&1

# our own drop-ins (purge leaves them behind): NAT include + AppArmor override
rm -f /etc/proftpd/conf.d/external_ip.conf
rm -f /etc/apparmor.d/local/proftpd
# reload if the profile outlived the purge (FORCE=yes edge) so the override stops applying
if [ -f /etc/apparmor.d/proftpd ]; then
	apparmor_parser -r /etc/apparmor.d/proftpd > /dev/null 2>&1 || true
fi

# clear FTP_SYSTEM only if it is proftpd (symmetric to the add side)
if [ "$FTP_SYSTEM" = 'proftpd' ]; then
	$BIN/h-change-sys-config-value 'FTP_SYSTEM' ''
fi

# firewall: drop the FTP rule by its COMMENT='FTP' id
if is_system_enabled "$FIREWALL_SYSTEM" 'FIREWALL_SYSTEM' > /dev/null 2>&1 \
	&& [ -f "$CONF_DIR/firewall/rules.conf" ]; then
	ftp_rule=$(grep "COMMENT='FTP'" "$CONF_DIR/firewall/rules.conf" \
		| sed -n "s/.*RULE='\([0-9]*\)'.*/\1/p" | head -n1)
	if [ -n "$ftp_rule" ]; then
		$BIN/h-delete-firewall-rule "$ftp_rule" > /dev/null 2>&1 || true
	fi
fi

set_install_component ADDON_PROFTPD false

echo "ProFTPD has been removed."

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

$BIN/h-log-action "system" "Info" "System" "Removed ProFTPD FTP server."
log_event "$OK" "$ARGUMENTS"

exit
