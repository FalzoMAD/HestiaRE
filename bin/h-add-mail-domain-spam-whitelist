#!/bin/bash
# info: add sender to per-domain spam whitelist
# options: USER DOMAIN SENDER
#
# example: h-add-mail-domain-spam-whitelist user domain.tld partner@example.com
# example: h-add-mail-domain-spam-whitelist user domain.tld '*.example.com'
#
# Adds a sender pattern to the domain's spam whitelist: matching mail is never
# treated as spam (rspamd scan skipped entirely). Whitelist wins over blacklist.
# Patterns match the lowercased envelope sender + its domain (wildlsearch); only
# applied while Spam Filter is enabled. Source of truth: U_SPAM_WHITELIST in
# mail.conf, mirrored one-per-line to the spam_whitelist file exim reads per message.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
domain=$2
sender=$(echo "$3" | tr '[:upper:]' '[:lower:]')

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

# Define mail user
if [ "$MAIL_SYSTEM" = 'exim4' ]; then
	MAIL_USER=Debian-exim
else
	MAIL_USER=exim
fi

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '3' "$#" 'USER DOMAIN SENDER'
is_format_valid 'user' 'domain'
# sender pattern: user@dom, *@dom, dom or *.dom — the domain part must be a
# plain domain (also keeps wildlsearch regex keys like ^... out of the file)
if [[ "$sender" == *"@"* ]]; then
	lpart="${sender%%@*}"
	dpart="${sender#*@}"
	if [ "$lpart" != '*' ] && ! [[ "$lpart" =~ ^[a-z0-9._+-]+$ ]]; then
		check_result "$E_INVALID" "invalid sender pattern :: $sender"
	fi
else
	dpart="${sender#\*.}"
fi
is_domain_format_valid "$dpart" 'sender domain'
is_system_enabled "$MAIL_SYSTEM" 'MAIL_SYSTEM'
is_system_enabled "$ANTISPAM_SYSTEM" 'ANTISPAM_SYSTEM'
is_object_valid 'user' 'USER' "$user"
is_object_unsuspended 'user' 'USER' "$user"
is_object_valid 'mail' 'DOMAIN' "$domain"
is_object_unsuspended 'mail' 'DOMAIN' "$domain"

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

list_file="$HOMEDIR/$user/conf/mail/$domain/spam_whitelist"
current=$(get_object_value 'mail' 'DOMAIN' "$domain" '$U_SPAM_WHITELIST')

# Idempotent: entry already present — nothing to do
if [[ ",$current," = *",$sender,"* ]]; then
	exit
fi

if [ -z "$current" ]; then
	new_list="$sender"
else
	new_list="$current,$sender"
fi

echo "$new_list" | tr ',' '\n' > "$list_file"
chown $MAIL_USER:mail "$list_file"
chmod 660 "$list_file"

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Adding whitelist value in config
add_object_key 'mail' 'DOMAIN' "$domain" 'U_SPAM_WHITELIST' 'ACCOUNTS'
update_object_value 'mail' 'DOMAIN' "$domain" '$U_SPAM_WHITELIST' "$new_list"

# Logging
$BIN/h-log-action "$user" "Info" "Mail" "Spam whitelist entry added (Domain: $domain, Sender: $sender)."
log_event "$OK" "$ARGUMENTS"

exit
