#!/bin/bash
# info: change phpmyadmin/phppgadmin alias url
# options: TYPE ALIAS
#
# example: h-change-sys-db-alias pma phpmyadmin
#          # Sets phpMyAdmin alias to phpmyadmin
#
# example: h-change-sys-db-alias pga phppgadmin
#          # Sets phpPgAdmin alias to phppgadmin
#
# This function changes the database editor url in
# apache2 or nginx configuration.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
type=$1
alias=$2

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

check_args '2' "$#" 'type alias'

is_common_format_valid "$alias" "Alias"

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# The database editors are served by the Panel-Caddy (port 8083) from a
# dedicated caddy FPM pool. Changing the alias (re)writes:
#   1. the Caddy route snippet under /etc/caddy/apps/ (imported in the :8083 site)
#   2. the per-customer-domain alias for nginx/apache, which transparently
#      reverse-proxies <domain>/<alias> into the Panel-Caddy (included per
#      domain vhost via `include .../{phpmyadmin,phppgadmin}.inc*`).
mkdir -p /etc/caddy/apps

# Detect common allowed entries for phpMyAdmin
if [ "$type" = "pma" ] || [ "$type" = "PMA" ] || [ "$type" = "phpmyadmin" ]; then
	# Set database editor friendly name
	db_editor="phpMyAdmin"
	# Set new alias value
	$BIN/h-change-sys-config-value 'DB_PMA_ALIAS' "$alias"

	# 1. Panel-Caddy route (delivery)
	cp -f "$HESTIA/share/panel-caddy/apps/phpmyadmin.tpl" /etc/caddy/apps/phpmyadmin.conf
	sed -i "s|%alias%|$alias|g" /etc/caddy/apps/phpmyadmin.conf
	$BIN/h-restart-service caddy

	# 2. Customer-domain alias -> transparent proxy into the Panel-Caddy
	if [ -d /etc/nginx/conf.d ]; then
		cp -f "$HESTIA/share/nginx/apps/phpmyadmin.inc" /etc/nginx/conf.d/phpmyadmin.inc
		sed -i "s|%pma_alias%|$alias|g" /etc/nginx/conf.d/phpmyadmin.inc
		$BIN/h-restart-service nginx
	fi
	if [ -d /etc/apache2/conf.d ]; then
		cp -f "$HESTIA/share/apache2/apps/phpmyadmin.conf" /etc/apache2/conf.d/phpmyadmin.inc
		sed -i "s|%pma_alias%|$alias|g" /etc/apache2/conf.d/phpmyadmin.inc
		$BIN/h-restart-service apache2
	fi
fi

# Detect common allowed entries for phpPgAdmin
if [ "$type" = "pga" ] || [ "$type" = "PGA" ] || [ "$type" = "phppgadmin" ]; then
	# Set database editor friendly name
	db_editor="phpPgAdmin"

	# Set new alias value
	$BIN/h-change-sys-config-value 'DB_PGA_ALIAS' "$alias"

	# 1. Panel-Caddy route (delivery)
	cp -f "$HESTIA/share/panel-caddy/apps/phppgadmin.tpl" /etc/caddy/apps/phppgadmin.conf
	sed -i "s|%alias%|$alias|g" /etc/caddy/apps/phppgadmin.conf
	$BIN/h-restart-service caddy

	# 2. Customer-domain alias -> transparent proxy into the Panel-Caddy
	if [ -d /etc/nginx/conf.d ]; then
		cp -f "$HESTIA/share/nginx/apps/phppgadmin.inc" /etc/nginx/conf.d/phppgadmin.inc
		sed -i "s|%pga_alias%|$alias|g" /etc/nginx/conf.d/phppgadmin.inc
		$BIN/h-restart-service nginx
	fi
	if [ -d /etc/apache2/conf.d ]; then
		cp -f "$HESTIA/share/apache2/apps/phppgadmin.conf" /etc/apache2/conf.d/phppgadmin.inc
		sed -i "s|%pga_alias%|$alias|g" /etc/apache2/conf.d/phppgadmin.inc
		$BIN/h-restart-service apache2
	fi
fi

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/h-log-action "system" "Info" "System" "System access alias changed (Tool: $db_editor, Alias: $alias)."
log_event "$OK" "$ARGUMENTS"

exit
