#!/bin/bash
# info: upgrade MariaDB to another version (in-place, with forced backup)
# options: [TARGET_VERSION]
#
# example: h-upgrade-sys-mariadb           # list available targets + reachability
# example: h-upgrade-sys-mariadb 11.8      # external MariaDB.org 11.8
# example: h-upgrade-sys-mariadb 11.4      # e.g. pin to what Magento supports
# example: h-upgrade-sys-mariadb __os__    # distribution package
#
# No argument = LIST the curated targets with the version each would actually
# deliver here (live from the repos) and whether it is reachable.
#
# In-place version switch: forced full dump -> repo switch (same dispatch as
# h-add-sys-mariadb) -> package upgrade -> restart -> mariadb-upgrade -> record.
# DBs stay in place. Multi-major jumps go direct (MariaDB supports skipping majors).
#
# DOWNGRADES ARE REFUSED (a newer datadir can't be reopened); the repo is restored.
#
# ROLLBACK (manual — not undoable in place). Using the dump this forces to /root (0600):
#   1. h-delete-sys-mariadb (FORCE=yes) && PURGE_DATA=yes   # drop new-format datadir
#   2. h-add-sys-mariadb <old-version>                      # reinstall old version
#   3. zcat <backup>.sql.gz | mariadb                       # restore the dump
#   4. mariadb -e "FLUSH PRIVILEGES;"

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

target="$1"

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"

REPO_LIST="/etc/apt/sources.list.d/mariadb.list"

# restore the pre-upgrade repo definition (used on refusal/abort before install)
_restore_repo() {
	if [ -f "${REPO_LIST}.bak" ]; then
		mv -f "${REPO_LIST}.bak" "$REPO_LIST"
	else
		rm -f "$REPO_LIST"
	fi
	apt-get -qq update > /dev/null 2>&1 || true
}

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

if [ "x$(id -u)" != 'x0' ]; then
	echo "Error: Script can be run executed only by root"
	exit 10
fi

# list mode: what each curated target would deliver here + whether it's reachable
if [ -z "$target" ]; then
	if ! dpkg -l mariadb-server 2> /dev/null | grep -q '^ii'; then
		echo "ERROR: MariaDB is not installed (use h-add-sys-mariadb)."
		exit "$E_NOTEXIST"
	fi
	current=$(mariadb -N -e "SELECT VERSION();" 2> /dev/null | grep -oE '^[0-9]+\.[0-9]+\.[0-9]+')
	echo "Running:  MariaDB ${current:-unknown}  (source: ${COMPONENT_DB_MARIADB_VERSION:-?})"
	echo ""
	echo "Available upgrade targets:"
	_os_id="$(. /etc/os-release; echo "$ID")"
	_codename="$(. /etc/os-release; echo "${VERSION_CODENAME:-}")"
	_arch="$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')"
	while IFS=$'\t' read -r _val _src _descr; do
		_cand=""
		if [ "$_val" = "__os__" ]; then
			# OS candidate: highest non-dlm version apt knows about
			_cand=$(LC_ALL=C apt-cache madison mariadb-server 2> /dev/null \
				| grep -v 'dlm.mariadb' | awk -F'|' 'NR==1{gsub(/ /,"",$2); print $2}' \
				| sed 's/^[0-9]*://' | grep -oE '^[0-9]+\.[0-9]+\.[0-9]+')
		else
			# external candidate: parse the repo Packages index (missing = not published here)
			_cand=$(curl -fsSL --max-time 10 \
				"https://dlm.mariadb.com/repo/mariadb-server/${_val}/repo/${_os_id}/dists/${_codename}/main/binary-${_arch}/Packages" 2> /dev/null \
				| awk '/^Package: mariadb-server$/{f=1} f&&/^Version:/{print $2; exit}' \
				| sed 's/^[0-9]*://' | grep -oE '^[0-9]+\.[0-9]+\.[0-9]+')
		fi
		if [ -z "$_cand" ]; then
			_state="n/a for ${_codename}"
		elif [ "$_cand" = "$current" ]; then
			_state="current"
		elif [ "$(printf '%s\n%s\n' "$current" "$_cand" | sort -V | tail -1)" = "$_cand" ]; then
			_state="upgrade OK"
		else
			_state="downgrade (refused)"
		fi
		printf '  %-7s -> %-9s %-22s %s\n' "$_val" "${_cand:--}" "$_state" "${_descr}"
	done < <(jq -r '.components.DB_MARIADB_VERSION.options[] | [.value, .source, (.description // "")] | @tsv' \
		"$HESTIA/share/manifest.json" 2> /dev/null)
	echo ""
	echo "Usage: h-upgrade-sys-mariadb <target>"
	exit 0
fi

case "$target" in
	12.3 | 11.8 | 11.4 | __os__) ;;
	*) echo "ERROR: unsupported target '$target' (expected 12.3|11.8|11.4|__os__)"; exit "$E_INVALID" ;;
esac

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

if ! dpkg -l mariadb-server 2> /dev/null | grep -q '^ii'; then
	echo "ERROR: MariaDB is not installed (use h-add-sys-mariadb)."
	exit "$E_NOTEXIST"
fi
if ! systemctl is-active --quiet mariadb; then
	echo "ERROR: MariaDB is not running — refusing to upgrade a stopped server."
	exit "$E_RESTART"
fi

current=$(mariadb -N -e "SELECT VERSION();" 2> /dev/null | grep -oE '^[0-9]+\.[0-9]+\.[0-9]+')
[ -n "$current" ] || { echo "ERROR: cannot determine running MariaDB version."; exit "$E_INVALID"; }

if [ "$target" = "${COMPONENT_DB_MARIADB_VERSION:-}" ]; then
	echo "INFO: MariaDB is already on '$target' — nothing to do."
	exit 0
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# 1. forced pre-upgrade dump (hard precondition) -> /root (0600), abort on error
backup="/root/mariadb-upgrade-backup-$(date +%F-%H%M%S).sql.gz"
echo "[ * ] Dumping all databases to $backup (forced pre-upgrade backup)..."
if ! mariadb-dump --all-databases --events --routines --triggers 2> /tmp/mdb-dump.err | gzip > "$backup"; then
	echo "ERROR: backup dump failed — upgrade aborted."
	sed 's/^/       | /' /tmp/mdb-dump.err 2> /dev/null | head -5
	rm -f "$backup"
	exit "$E_INVALID"
fi
chmod 600 "$backup"
[ -s "$backup" ] || { echo "ERROR: backup file is empty — upgrade aborted."; rm -f "$backup"; exit "$E_INVALID"; }

# 2. repo switch, keeping the old state for restore-on-refusal
[ -f "$REPO_LIST" ] && cp -f "$REPO_LIST" "${REPO_LIST}.bak"
ARCH="$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/')"
OS_ID="$(. /etc/os-release; echo "$ID")"
CODENAME="$(. /etc/os-release; echo "${VERSION_CODENAME:-}")"
case "$target" in
	12.3 | 11.8 | 11.4)
		echo "[ * ] Switching to MariaDB.org $target repo..."
		printf 'deb [arch=%s signed-by=/usr/share/keyrings/mariadb-keyring.gpg] https://dlm.mariadb.com/repo/mariadb-server/%s/repo/%s %s main\n' \
			"$ARCH" "$target" "$OS_ID" "$CODENAME" > "$REPO_LIST"
		if [ ! -s /usr/share/keyrings/mariadb-keyring.gpg ]; then
			curl -fsSL https://mariadb.org/mariadb_release_signing_key.asc -o /tmp/mariadb_signing.asc \
				|| { echo "ERROR: failed to download MariaDB signing key"; _restore_repo; exit 1; }
			gpg --dearmor < /tmp/mariadb_signing.asc > /usr/share/keyrings/mariadb-keyring.gpg
			rm -f /tmp/mariadb_signing.asc
		fi
		;;
	__os__)
		echo "[ * ] Switching to the OS package (removing external repo)..."
		rm -f "$REPO_LIST"
		;;
esac
apt-get -qq update

# 3. downgrade refusal: compare apt's candidate to the running version
#    (LC_ALL=C so the localized "Candidate:" line still matches)
candidate=$(LC_ALL=C apt-cache policy mariadb-server 2> /dev/null | awk '/Candidate:/{print $2}' \
	| sed 's/^[0-9]*://' | grep -oE '^[0-9]+\.[0-9]+\.[0-9]+')
if [ -z "$candidate" ]; then
	echo "ERROR: no installation candidate for mariadb-server after repo switch."
	_restore_repo
	rm -f "$backup"   # nothing was changed — drop the unused pre-upgrade dump
	exit "$E_INVALID"
fi
# an older-only target makes apt's candidate fall back to the installed version, so
# both downgrade and no-newer cases land here
if [ "$(printf '%s\n%s\n' "$current" "$candidate" | sort -V | tail -1)" != "$candidate" ] \
	|| [ "$current" = "$candidate" ]; then
	echo "ERROR: target '$target' offers nothing newer than the running $current"
	echo "       (candidate: $candidate) — downgrades are refused: MariaDB cannot"
	echo "       open a datadir written by a newer version."
	echo "       To go back anyway: restore from a dump (see the command header)."
	_restore_repo
	rm -f "$backup"   # nothing was changed — drop the unused pre-upgrade dump
	exit "$E_INVALID"
fi
echo "[ * ] Upgrading MariaDB $current -> $candidate..."

# 4. package upgrade (apt bounces the service via maintainer scripts)
if ! DEBIAN_FRONTEND=noninteractive apt-get -y -qq \
	-o Dpkg::Options::="--force-confold" \
	install mariadb-server mariadb-client mariadb-common > /dev/null 2>&1; then
	echo "ERROR: package upgrade failed — MariaDB may be in a mixed state."
	echo "       Backup for recovery: $backup (rollback: see command header)."
	exit "$E_INVALID"
fi
rm -f "${REPO_LIST}.bak"

# 5. Restart + system-table migration.
systemctl restart mariadb
if ! systemctl is-active --quiet mariadb; then
	echo "ERROR: MariaDB failed to start after upgrade."
	echo "       Backup for recovery: $backup (rollback: see command header)."
	exit "$E_RESTART"
fi
echo "[ * ] Running mariadb-upgrade (system table migration)..."
mariadb-upgrade > /dev/null 2>&1 || mariadb-upgrade --force > /dev/null 2>&1 || true

# 6. Verify the panel path still works (socket auth + host registration).
if ! mariadb -e "SELECT 1;" > /dev/null 2>&1; then
	echo "ERROR: post-upgrade login check failed."
	echo "       Backup for recovery: $backup"
	exit "$E_INVALID"
fi
new_version=$(mariadb -N -e "SELECT VERSION();" 2> /dev/null | grep -oE '^[0-9]+\.[0-9]+\.[0-9]+')

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

set_install_component DB_MARIADB_VERSION "$target"

echo "[ OK ] MariaDB upgraded: $current -> $new_version (source: $target)"
echo "       Pre-upgrade backup kept at: $backup"

$BIN/h-log-action "system" "Info" "System" "MariaDB upgraded $current -> $new_version (target $target)."
log_event "$OK" "$ARGUMENTS"

exit
