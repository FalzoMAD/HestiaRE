#!/bin/bash
# info: add sieve mail filtering (ManageSieve + delivery-time execution)
# options: NONE
#
# example: h-add-sys-sieve
#
# Installs dovecot-managesieved + dovecot-sieve and wires them up: the
# version-specific sieve conf.d overlay (share/dovecot/<ver>/sieve/) enables
# the sieve protocol on port 4190 (localhost consumers like the webmail
# managesieve plugin; not opened in the firewall) and stores scripts per
# account inside the account maildir. exim's SIEVE macro switches clean local
# delivery to dovecot-lda so the scripts actually run at delivery time; spam
# keeps the direct .Spam appendfile path (exim's verdict is final).
#
# Consequence to be aware of: sieve scripts run ONLY on non-spam mail. Messages
# rspamd marks as spam bypass dovecot-lda and land in .Spam directly, so a
# customer's own sieve rules never see them (spam foldering is exim's job, not
# sieve's). Over-quota behaviour is kept identical on both paths (defer, not
# bounce) via quota_full_tempfail + return_fail_output — see share/dovecot/
# <ver>/sieve/15-lda.conf and the dovecot_virtual_delivery transport.
# Also called by the installer (COMPONENT_ADDON_SIEVE).
# New h-* command — no v-* symlink.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Includes
# shellcheck source=/etc/hestia/hestia.env
source /etc/hestia/hestia.env
# shellcheck source=/usr/local/hestia/func/main.sh
source $HESTIA/func/main.sh
# load config file
source_conf "$HESTIA/conf/hestia.conf"
# live component state
[ -f "$CONF_DIR/install.conf" ] && source "$CONF_DIR/install.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

# Checking root permissions
if [ "x$(id -u)" != 'x0' ]; then
	echo "Error: Script can be run executed only by root"
	exit 10
fi

is_system_enabled "$MAIL_SYSTEM" 'MAIL_SYSTEM'
is_system_enabled "$IMAP_SYSTEM" 'IMAP_SYSTEM'

# Perform verification if read-only mode is enabled
check_hestia_demo_mode

if [ "$SIEVE_SYSTEM" = 'yes' ] && dpkg -l dovecot-managesieved 2> /dev/null | grep -q '^ii'; then
	echo "ERROR: sieve is already installed."
	exit "$E_EXISTS"
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

echo "Installing sieve (dovecot-managesieved, dovecot-sieve)..."
apt-get -y -qq install dovecot-managesieved dovecot-sieve > /dev/null 2>&1
if ! dpkg -l dovecot-managesieved 2> /dev/null | grep -q '^ii'; then
	echo "ERROR: sieve installation failed."
	exit "$E_INVALID"
fi

# Version-specific overlay (2.3 deb12 / 2.4 deb13) — replaces the package
# defaults: sieve protocol, per-account script storage, dovecot-lda plugins
DOVECOT_VER=$(dovecot --version 2> /dev/null | cut -d. -f1,2 || echo "2.3")
if [ "$(printf '%s\n2.4' "$DOVECOT_VER" | sort -V | head -1)" = "2.4" ]; then
	DCDIR="$HESTIA/share/dovecot/2.4"
else
	DCDIR="$HESTIA/share/dovecot/2.3"
fi
cp -f "$DCDIR/sieve/"* /etc/dovecot/conf.d/
# global script dir referenced by the sieve config (pipe/global extensions)
mkdir -p /etc/dovecot/sieve

systemctl restart dovecot
if ! systemctl is-active --quiet dovecot; then
	echo "ERROR: dovecot failed to restart with sieve enabled."
	exit "$E_RESTART"
fi

# Switch clean local delivery to dovecot-lda (dovecot_virtual_delivery
# transport) so sieve scripts run at delivery
sed -i 's/^#SIEVE = yes/SIEVE = yes/' /etc/exim4/exim4.conf.template
systemctl restart exim4
if ! systemctl is-active --quiet exim4; then
	echo "ERROR: exim4 failed to restart with sieve delivery enabled."
	exit "$E_RESTART"
fi

$BIN/h-change-sys-config-value 'SIEVE_SYSTEM' 'yes'
set_install_component ADDON_SIEVE true

echo "sieve is now active (ManageSieve on 4190, scripts run at delivery)."

#----------------------------------------------------------#
#                       Hestia                             #
#----------------------------------------------------------#

# Logging
$BIN/h-log-action "system" "Info" "System" "Installed sieve mail filtering."
log_event "$OK" "$ARGUMENTS"

exit
